<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title || 'GPI Eluzai Kids' %></title>
    <link rel="icon" type="image/png" href="/images/logo-placeholder.png">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer">

    <!-- Vercel Analytics -->
    <script>window.va=window.va||function(){(window.vaq=window.vaq||[]).push(arguments)};</script>
    <script defer src="/_vercel/insights/script.js"></script>

    <!-- Vercel Speed Insights -->
    <script defer src="https://unpkg.com/@vercel/speed-insights/dist/index.js"></script>
  </head>
  <body class="page-is-ready">
    <% const shouldHideNavbar = typeof hideNavbar === 'undefined' ? false : hideNavbar; %>

    <% if (!shouldHideNavbar) { %>
      <nav class="nav" aria-label="Navigasi utama">
        <div class="nav-inner">

          <a class="brand" href="/" aria-label="Homepage">
            <img src="/images/logo-placeholder.png" alt="Gereja" class="logo-img" width="46" height="46">
          </a>

          <button class="nav-toggle" aria-label="Buka navigasi" aria-expanded="false" type="button">
            <span class="hamburger"></span>
          </button>

          <button class="theme-toggle" aria-label="Ganti tema" title="Ganti tema" type="button">🌙</button>

          <div class="nav-date" aria-label="Tanggal dan waktu">
            <span class="nav-date-day" id="nav-date-day">-</span>
            <span class="nav-date-value" id="nav-date-value">-</span>
            <span class="nav-date-time" id="nav-date-time">-</span>
            <span class="nav-date-suffix">&nbsp;</span>
          </div>

          <!-- Notification Bell -->
          <% const hasEvents = typeof events !== 'undefined' && events && events.length; %>
          <div class="nav-notif" id="nav-notif">
            <button class="nav-notif-btn" id="nav-notif-btn" type="button" aria-label="Notifikasi">
              <i class="fas fa-bell"></i>
              <% if (hasEvents) { %><span class="nav-notif-dot"></span><% } %>
            </button>
            <!-- Notification Popup -->
            <% if (hasEvents) { %>
              <% const latestEvent = events[0]; %>
              <div class="nav-notif-popup" id="nav-notif-popup">
                <div class="nav-notif-header">Notifikasi</div>
                <a class="nav-notif-item" href="#events">
                  <div class="nav-notif-icon"><i class="fas fa-calendar-alt"></i></div>
                  <div class="nav-notif-body">
                    <span class="nav-notif-label">Event Terbaru</span>
                    <span class="nav-notif-title"><%= latestEvent.title %></span>
                    <span class="nav-notif-time">
                      <%= (() => {
                        const s = String(latestEvent.day || '').trim();
                        let d = null;
                        const m1 = s.match(/^(\d{4})-(\d{2})-(\d{2})$/);
                        if (m1) d = new Date(Number(m1[1]), Number(m1[2]) - 1, Number(m1[3]));
                        if (!d || Number.isNaN(d.getTime())) return s;
                        const dd = String(d.getDate()).padStart(2, '0');
                        const mm = String(d.getMonth() + 1).padStart(2, '0');
                        const yyyy = d.getFullYear();
                        return `${dd}/${mm}/${yyyy}`;
                      })() %>
                      <% if (latestEvent.time) { %> | <%= latestEvent.time %><% } %>
                    </span>
                  </div>
                </a>
              </div>
            <% } %>
          </div>

          <ul class="nav-links">
            <li>
              <a href="#home"><i class="fas fa-home nav-link-icon"></i> Home</a>
            </li>
            <li>
              <a href="#events"><i class="fas fa-calendar-alt nav-link-icon"></i> Event</a>
            </li>
            <li>
              <a href="#documentation"><i class="fas fa-folder-open nav-link-icon"></i> Documentation Event</a>
            </li>
            <li>
              <a href="#address"><i class="fas fa-map-marker-alt nav-link-icon"></i> Address</a>
            </li>
            <li>
              <a href="#footer"><i class="fas fa-envelope nav-link-icon"></i> Contact</a>
            </li>
          </ul>
        </div>
      </nav>
    <% } %>
    <main class="container">

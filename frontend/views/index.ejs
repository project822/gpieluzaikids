<%- include('partials/header', { title: 'Home' }) %>

<!-- Hero Section -->
<section class="hero reveal" id="home">
  <div class="hero-content">
    <img
      src="/images/logo-placeholder.png"
      alt="Logo"
      class="hero-logo-img"
      width="72"
      height="72"
      fetchpriority="high"
    >
    <h1 class="logo-title">GPI Eluzai Kids</h1>
    <p class="lead hero-lead">Aku Diberkati, Kamu Diberkati, Kita Semua Diberkati.</p>
    <div class="hero-ctas">
      <a class="btn primary" href="#events">Lihat Event</a>
      <a class="btn ghost" href="#footer">Ikuti Kami</a>
    </div>
  </div>
</section>

<!-- Event Alert Banner -->
<% if (events && events.length) { %>
  <% const latestEvent = events[0]; %>
  <a class="event-alert-banner" href="#events" id="event-alert-banner">
    <div class="event-alert-inner">
      <span class="event-alert-badge">Event Terbaru</span>
      <span class="event-alert-title"><%= latestEvent.title %></span>
      <span class="event-alert-meta">
        <i class="fas fa-calendar-alt"></i>
        <%= (() => {
          const s = String(latestEvent.day || '').trim();
          let d = null;
          const m1 = s.match(/^(\d{4})-(\d{2})-(\d{2})$/);
          if (m1) d = new Date(Number(m1[1]), Number(m1[2]) - 1, Number(m1[3]));
          if (!d || Number.isNaN(d.getTime())) return s;
          const dd = String(d.getDate()).padStart(2, '0');
          const mm = String(d.getMonth() + 1).padStart(2, '0');
          const yyyy = d.getFullYear();
          return `${dd}/${mm}/${yyyy}`;
        })() %>
        <% if (latestEvent.time) { %>
          &nbsp;|&nbsp; <i class="fas fa-clock"></i> <%= latestEvent.time %>
        <% } %>
      </span>
    </div>
    <span class="event-alert-arrow">&rarr;</span>
  </a>
<% } %>

<!-- Events Section -->
<section id="events" class="section reveal">
  <div class="section-header">
    <h2>Upcoming Events</h2>
    <p>Lihat jadwal acara kami yang akan datang.</p>
  </div>

  <div class="carousel-wrapper events-carousel" id="events-carousel" data-carousel-mode="single">
    <div class="carousel-track">

    <% if (events && events.length) { %>
      <% events.forEach((event) => { %>
        <div class="carousel-item slide" data-id="<%= event.id %>">
          <div class="slide-card">
            <% if (event.poster) { %>
              <div class="poster" style="background-image: url('<%= event.poster %>');"></div>
            <% } else { %>
              <div class="poster placeholder"></div>
            <% } %>

            <div class="meta">
              <h3><%= event.title %></h3>
              <p class="time">
                <%= (() => {
                  const s = String(event.day || '').trim();
                  let d = null;
                  const m1 = s.match(/^(\d{4})-(\d{2})-(\d{2})$/);
                  if (m1) d = new Date(Number(m1[1]), Number(m1[2]) - 1, Number(m1[3]));
                  else {
                    const m2 = s.match(/^(\d{2})\/(\d{2})\/(\d{4})$/);
                    if (m2) d = new Date(Number(m2[3]), Number(m2[2]) - 1, Number(m2[1]));
                  }
                  if (!d || Number.isNaN(d.getTime())) return s;
                  return `${String(d.getDate()).padStart(2, '0')}/${String(d.getMonth() + 1).padStart(2, '0')}/${d.getFullYear()}`;
                })() %> | <%= event.time %>
              </p>
              <p class="location"><%= event.location %></p>

              <div class="actions">
                <% if (event.googleForm) { %>
                  <a class="btn primary btn-sm" href="<%= event.googleForm %>" target="_blank" rel="noopener">Daftar</a>
                <% } else { %>
                  <span class="btn ghost btn-sm" style="cursor: default; opacity: 0.5;" aria-disabled="true">Daftar</span>
                <% } %>
                <button class="btn ghost btn-sm view-details" data-id="<%= event.id %>" type="button">Detail</button>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="carousel-item" style="display:flex; align-items:center; justify-content:center;">
        <p class="lead" style="width: 100%; text-align: center;">Belum ada event.</p>
      </div>
    <% } %>
    </div>

    <button class="carousel-btn prev" type="button" aria-label="Sebelumnya">‹</button>
    <button class="carousel-btn next" type="button" aria-label="Berikutnya">›</button>
  </div>
</section>

<!-- Documentation Section -->
<section id="documentation" class="section reveal">
  <div class="section-header">
    <h2>Dokumentasi Event</h2>
    <p>Dokumentasi acara dapat diakses melalui Google Drive.</p>
  </div>

  <div class="carousel-wrapper docs-carousel" id="docs-carousel" data-carousel-mode="single">
    <div class="carousel-track" id="docs-carousel-track">

    <% if (events && events.length) { %>
      <% events.forEach((event) => { %>
        <div class="carousel-item doc-slide">
          <div class="slide-card doc-slide-card">
            <div class="meta doc-slide-meta">
              <h3 class="doc-slide-title"><%= event.title %></h3>
              <% if (event.driveLink) { %>
                <a class="btn primary btn-sm" href="<%= event.driveLink %>" target="_blank" rel="noopener">Buka Google Drive</a>
              <% } else { %>
                <span class="btn ghost btn-sm" style="cursor: default;">Link Google Drive belum tersedia</span>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="carousel-item" style="display:flex; align-items:center; justify-content:center;">
        <p class="lead" style="width: 100%; text-align: center;">Belum ada data event.</p>
      </div>
    <% } %>
    </div>

    <button class="carousel-btn prev" type="button" aria-label="Sebelumnya">‹</button>
    <button class="carousel-btn next" type="button" aria-label="Berikutnya">›</button>
  </div>
</section>

<!-- Address Section -->
<section id="address" class="section reveal">
  <div class="section-header">
    <h2>Alamat</h2>
    <p>Mari beribadah bersama kami.</p>
  </div>

  <div class="address-grid">
    <div class="map-frame">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3957.652535728212!2d112.714429!3d-7.280318!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2dd7fd0015087f33%3A0xf0f9599548b15626!2sGPI%20ELUZAI!5e0!3m2!1sid!2sid!4v1783601161439!5m2!1sid!2sid"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      ></iframe>
    </div>

    <div class="address-card">
      <h2 style="font-size: 1.2rem; margin: 0 0 12px; color: var(--text);">GPI Eluzai Kids</h2>
      <p style="margin: 0 0 16px; color: var(--text-secondary); line-height: 1.7;">
        Jl. Dukuh Kupang Timur XVII No. 28<br>
        Surabaya, Jawa Timur 60255
      </p>
      <a class="btn primary btn-sm" href="https://www.google.com/maps/place/GPI+ELUZAI/@-7.280318,112.714429,17z/data=!3m1!4b1!4m6!3m5!1s0x2dd7fd0015087f33:0xf0f9599548b15626!8m2!3d-7.280318!4d112.714429!16s%2Fg%2F11y79_ln7k?entry=ttu&g_ep=EgoyMDI2MDcwNi4wIKXMDSoASAFQAw%3D%3D" target="_blank" rel="noopener">
        Buka di Google Maps
      </a>
    </div>
  </div>
</section>

<!-- Event Modal -->
<div id="event-modal" class="modal" aria-hidden="true">
  <div class="modal-dialog">
    <button class="modal-close" aria-label="Tutup" type="button">&times;</button>
    <div class="modal-body">
      <img id="modal-poster" src="" alt="Poster event">
      <div>
        <h3 id="modal-title" style="margin-bottom: 12px; color: var(--text);"></h3>
        <p id="modal-time" style="color: var(--text-secondary); margin-bottom: 8px;"></p>
        <p id="modal-location" style="color: var(--text-secondary); margin-bottom: 8px;"></p>
        <p id="modal-desc" style="color: var(--text-secondary); margin-bottom: 16px;"></p>
        <div id="modal-actions"></div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
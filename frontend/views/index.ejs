<%- include('header', { title: 'Home', events: typeof events !== 'undefined' ? events : null }) %>

<section class="hero modern-hero reveal" id="home">
<div class="hero-overlay">
    <div
      class="layer hero-parallax"
      style="background: radial-gradient(circle at 20% 30%, rgba(14, 165, 164, 0.12), transparent 12%); opacity: 0.9;"
    ></div>
    <div
      class="layer hero-parallax"
      style="background: radial-gradient(circle at 80% 70%, rgba(37, 99, 235, 0.12), transparent 12%); opacity: 0.85;"
    ></div>
  </div>


  <div class="hero-content">
    <div class="hero-card auth-card">
      <div class="logo-wrap hero-logo-wrap">
        <img
          src="/images/logo-placeholder.png"
          alt="Logo"
          class="hero-logo-img"
          width="56"
          height="56"
          fetchpriority="high">
        <h1 class="logo-title">GPI Eluzai Kids</h1>
      </div>

      <p class="lead hero-lead">Aku Diberkati, Kamu Diberkati, Kita Semua Diberkati.</p>

      <div class="hero-ctas hero-ctas-home">
        <a class="btn primary" href="#events">Lihat Event</a>
        <a class="btn ghost" href="#footer">Ikuti Kami</a>
      </div>
    </div>
  </div>
</section>


<section id="events" class="section events-section reveal">
  <div class="section-header">
    <h2>Upcoming Events</h2>
  </div>

  <div class="events-showcase" id="events-showcase">

    <% if (events && events.length) { %>

      <div class="events-showcase-inner" id="events-showcase-inner">

      <% events.forEach((event, idx) => { %>
        <div class="events-slide" data-id="<%= event.id %>" data-index="<%= idx %>">
          <div class="events-slide-layout">

            <!-- Poster 9:16 -->
            <div class="events-poster-col">
              <% if (event.poster) { %>
                <% if (idx === 0) { %>
                  <!-- Slide pertama = kemungkinan besar LCP element: load eager, JANGAN lazy -->
                  <div class="events-poster" style="aspect-ratio: 9 / 16; background-image: url('<%= event.poster %>');"></div>
                <% } else { %>
                  <!-- Slide selanjutnya: lazy via IntersectionObserver (lihat script di bawah) -->
                  <div class="events-poster events-poster-lazy" style="aspect-ratio: 9 / 16;" data-bg="<%= event.poster %>"></div>
                <% } %>
              <% } else { %>
                <div class="events-poster placeholder" style="aspect-ratio: 9 / 16;"></div>
              <% } %>
            </div>

            <!-- Detail -->
            <div class="events-detail-col">
              <div class="events-detail-inner">
                <h3 class="events-detail-title"><%= event.title %></h3>

                <div class="events-detail-meta">
                  <div class="events-meta-item">
                    <i class="fas fa-calendar-alt"></i>
                    <span>
                      <%= (() => {
                        const s = String(event.day || '').trim();
                        let d = null;
                        const m1 = s.match(/^(\d{4})-(\d{2})-(\d{2})$/);
                        if (m1) d = new Date(Number(m1[1]), Number(m1[2]) - 1, Number(m1[3]));
                        if (!d || Number.isNaN(d.getTime())) return s;
                        const dd = String(d.getDate()).padStart(2, '0');
                        const mm = String(d.getMonth() + 1).padStart(2, '0');
                        const yyyy = d.getFullYear();
                        return `${dd}/${mm}/${yyyy}`;
                      })() %>
                    </span>
                  </div>

                  <% if (event.time) { %>
                  <div class="events-meta-item">
                    <i class="fas fa-clock"></i>
                    <span><%= event.time %></span>
                  </div>
                  <% } %>

                  <% if (event.location) { %>
                  <div class="events-meta-item">
                    <i class="fas fa-map-marker-alt"></i>
                    <span><%= event.location %></span>
                  </div>
                  <% } %>
                </div>

                <% if (event.description) { %>
                <p class="events-detail-desc"><%= event.description %></p>
                <% } %>

                <div class="events-detail-actions">
                  <% if (event.googleForm) { %>
                    <a class="btn primary" href="<%= event.googleForm %>" target="_blank" rel="noopener">
                      <i class="fas fa-external-link-alt"></i> Daftar
                    </a>
                  <% } else { %>
                    <span class="btn ghost" style="cursor: default; opacity: 0.7;" aria-disabled="true">Daftar</span>
                  <% } %>
                  <button class="btn ghost view-details" data-id="<%= event.id %>" type="button">
                    <i class="fas fa-info-circle"></i> Detail
                  </button>
                </div>
              </div>
            </div>

          </div>
        </div>
      <% }) %>

      </div>

      <!-- Dots navigation -->
      <div class="events-dots" id="events-dots"></div>

    <% } else { %>
      <div style="display:flex; align-items:center; justify-content:center; padding: 40px 0;">
        <p class="lead" style="width: 100%; text-align: center;">Belum ada event.</p>
      </div>
    <% } %>

  </div>
</section>



<section id="documentation" class="section docs-section reveal">
  <div class="section-header">
    <h2>Dokumentasi Event</h2>
    <p>Dokumentasi acara dapat diakses melalui Google Drive.</p>
  </div>

  <div class="docs-grid-slider" id="docs-slider">
    <div class="docs-grid-track" id="docs-grid-track">

    <% if (events && events.length) { %>

      <% events.forEach((event) => { %>
        <div class="docs-grid-item">
          <div class="docs-grid-card">
            <div class="docs-grid-body">
              <h3 class="docs-grid-title"><%= event.title %></h3>
              <% if (event.driveLink) { %>
                <a class="btn primary btn-sm" href="<%= event.driveLink %>" target="_blank" rel="noopener">
                  <i class="fas fa-external-link-alt"></i> Buka Google Drive
                </a>
              <% } else { %>
                <span class="btn ghost btn-sm" style="cursor: default; opacity: 0.7;">Link Google Drive belum tersedia</span>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="docs-grid-item" style="display:flex; align-items:center; justify-content:center; grid-column: 1 / -1;">
        <p class="lead" style="width: 100%; text-align: center;">Belum ada data event.</p>
      </div>

    <% } %>
    </div>

    <div class="docs-slider-nav">
      <button class="docs-slider-btn prev" type="button" aria-label="Sebelumnya">‹</button>
      <span class="docs-slider-pages" id="docs-slider-pages">1 / 1</span>
      <button class="docs-slider-btn next" type="button" aria-label="Berikutnya">›</button>
    </div>
  </div>
</section>

<section id="address" class="section address-section reveal">
  <div class="section-header">
    <h2>Alamat</h2>
    <p>Mari beribadah bersama kami.</p>
  </div>

  <div class="address-grid">
    <div class="map-frame">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3957.652535728212!2d112.714429!3d-7.280318!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2dd7fd0015087f33%3A0xf0f9599548b15626!2sGPI%20ELUZAI!5e0!3m2!1sid!2sid!4v1783601161439!5m2!1sid!2sid"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      ></iframe>
    </div>

    <div class="address-card">
      <div class="section-header" style="text-align: left; margin-bottom: 12px;">
        <h2 style="font-size: 1.4rem; margin: 0;">GPI Eluzai Kids</h2>
      </div>

      <p style="margin: 0 0 14px; color: var(--muted); line-height: 1.7;">
        Jl. Dukuh Kupang Timur XVII No. 28<br>
        Surabaya, Jawa Timur 60255
      </p>

      <a
        class="btn primary"
        href="https://www.google.com/maps/place/GPI+ELUZAI/@-7.280318,112.714429,17z/data=!3m1!4b1!4m6!3m5!1s0x2dd7fd0015087f33:0xf0f9599548b15626!8m2!3d-7.280318!4d112.714429!16s%2Fg%2F11y79_ln7k?entry=ttu&g_ep=EgoyMDI2MDcwNi4wIKXMDSoASAFQAw%3D%3D"
        target="_blank"
        rel="noopener"
        style="display: inline-block;"
      >
        Buka di Google Maps
      </a>
    </div>
  </div>
</section>

<div id="event-modal" class="modal" aria-hidden="true">
  <div class="modal-dialog">
    <button class="modal-close" aria-label="Tutup" type="button">&times;</button>
    <div class="modal-body">
      <img id="modal-poster" src="" alt="Poster event" loading="lazy" decoding="async">
      <div>
        <h3 id="modal-title"></h3>
        <p id="modal-time"></p>
        <p id="modal-location"></p>
        <p id="modal-desc"></p>
        <div id="modal-actions"></div>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  // Lazy-load poster event (selain slide pertama) pakai IntersectionObserver.
  // Background-image tidak bisa pakai atribut loading="lazy" bawaan browser,
  // makanya URL-nya disimpan di data-bg dulu dan baru dipasang saat elemen
  // mendekati viewport.
  var lazyPosters = document.querySelectorAll('.events-poster-lazy[data-bg]');
  if (!lazyPosters.length) return;

  if (!('IntersectionObserver' in window)) {
    // Fallback browser lama: langsung pasang semua
    lazyPosters.forEach(function (el) {
      el.style.backgroundImage = "url('" + el.dataset.bg + "')";
    });
    return;
  }

  var observer = new IntersectionObserver(
    function (entries, obs) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          var el = entry.target;
          el.style.backgroundImage = "url('" + el.dataset.bg + "')";
          el.classList.remove('events-poster-lazy');
          obs.unobserve(el);
        }
      });
    },
    { rootMargin: '200px 0px' }
  );

  lazyPosters.forEach(function (el) { observer.observe(el); });
})();
</script>

<%- include('footer') %>

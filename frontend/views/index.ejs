    </div>

    <div class="address-card">
      <div class="section-header" style="text-align: left; margin-bottom: 12px;">
        <h2 style="font-size: 1.4rem; margin: 0;">GPI Eluzai Kids</h2>
      </div>

      <p style="margin: 0 0 14px; color: var(--muted); line-height: 1.7;">
        Jl. Dukuh Kupang Timur XVII No. 28<br>
        Surabaya, Jawa Timur 60255
      </p>

      <a
        class="btn primary"
        href="https://www.google.com/maps/place/GPI+ELUZAI/@-7.280318,112.714429,17z/data=!3m1!4b1!4m6!3m5!1s0x2dd7fd0015087f33:0xf0f9599548b15626!8m2!3d-7.280318!4d112.714429!16s%2Fg%2F11y79_ln7k?entry=ttu&g_ep=EgoyMDI2MDcwNi4wIKXMDSoASAFQAw%3D%3D"
        target="_blank"
        rel="noopener"
        style="display: inline-block;"
      >
        Buka di Google Maps
      </a>
    </div>
  </div>
</section>

<div id="event-modal" class="modal" aria-hidden="true">
  <div class="modal-dialog">
    <button class="modal-close" aria-label="Tutup" type="button">&times;</button>
    <div class="modal-body" id="modal-body">
      <img id="modal-poster" src="" alt="Poster event" loading="lazy" decoding="async">
      <div class="modal-body-content">
        <h3 id="modal-title"></h3>
        <p id="modal-time"></p>
        <p id="modal-location"></p>
        <p id="modal-desc"></p>
        <div id="modal-actions"></div>
      </div>
    </div>
  </div>
</div>

<script>
// Modal detail event: seluruh logic (fetch, isi konten, buka/tutup)
// ditangani SATU tempat saja yaitu main.js (bagian "7) Event modal").
// Dulu ada script duplikat di sini yang bind ke tombol .view-details
// yang sama → setiap klik memicu 2 fetch + 2 penulisan DOM sekaligus,
// menyebabkan race condition (poster kadang tak muncul, teks acak).
// JANGAN tambahkan handler modal lain di file ini.

(function () {
  // Lazy-load poster event (selain slide pertama) pakai IntersectionObserver.
  // Background-image tidak bisa pakai atribut loading="lazy" bawaan browser,
  // makanya URL-nya disimpan di data-bg dulu dan baru dipasang saat elemen
  // mendekati viewport.
  var lazyPosters = document.querySelectorAll('.events-poster-lazy[data-bg]');
  if (!lazyPosters.length) return;

  if (!('IntersectionObserver' in window)) {
    // Fallback browser lama: langsung pasang semua
    lazyPosters.forEach(function (el) {
      el.style.backgroundImage = "url('" + el.dataset.bg + "')";
    });
    return;
  }

  var observer = new IntersectionObserver(
    function (entries, obs) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          var el = entry.target;
          el.style.backgroundImage = "url('" + el.dataset.bg + "')";
          el.classList.remove('events-poster-lazy');
          obs.unobserve(el);
        }
      });
    },
    { rootMargin: '200px 0px' }
  );

  lazyPosters.forEach(function (el) { observer.observe(el); });
})();
</script>

<%- include('footer') %>

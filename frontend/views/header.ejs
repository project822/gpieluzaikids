    <!-- Preconnect & preload Google Fonts for Deep Ocean typography -->
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@600;700;800&family=Inter:wght@400;500;600;700&family=Geist:wght@400;500;600&display=swap" as="style">

    <!-- Poster event pertama = kemungkinan besar LCP element di homepage,
         mulai download sedini mungkin (jangan tunggu HTML selesai di-parse) -->
    <% if (typeof events !== 'undefined' && events && events.length && events[0].poster) { %>
      <link rel="preload" href="<%= events[0].poster %>" as="image" fetchpriority="high">
    <% } %>

    <!-- Inline critical CSS (above-fold) — TechNexus Deep Ocean -->
    <style>/* ── Deep Ocean: Critical Above-Fold Styles ── */:root{--font-display:'Hanken Grotesk',system-ui,sans-serif;--font-body:'Inter',system-ui,sans-serif;--font-label:'Geist',monospace,sans-serif;--font-sans:var(--font-body);--electric-blue:#3B82F6;--navy:#0F172A;--white:#FFFFFF;--surface:#1E293B;--surface-dim:#10131a;--surface-container-high:#272a31;--surface-container-highest:#32353c;--on-surface:#FFFFFF;--on-surface-variant:#94A3B8;--outline:#334155;--accent:var(--electric-blue);--accent-hover:#2563eb;--danger:#ef4444;--text-color:var(--on-surface);--section-heading:var(--on-surface);--muted:var(--on-surface-variant);--text-muted:var(--on-surface-variant);--text-secondary:var(--on-surface-variant);--surface-hover:var(--surface-container-high);--surface-strong:var(--surface-container-highest);--glass-bg:rgba(30,41,59,0.5);--glass-border:rgba(51,65,85,0.5);--glass-blur:12px;--glow-blue:rgba(59,130,246,0.12);--elevation-low:0 0 0 1px var(--glass-border),0 0 20px rgba(59,130,246,0.05);--elevation-md:0 0 0 1px var(--glass-border),0 0 30px rgba(59,130,246,0.08);--elevation-high:0 0 0 1px rgba(59,130,246,0.2),0 0 40px rgba(59,130,246,0.12);--shadow:var(--elevation-md);--shadow-lg:var(--elevation-high);--shadow-soft:var(--elevation-low);--border:var(--glass-border);--border-accent:rgba(59,130,246,0.3);--ghost-border:rgba(255,255,255,0.12);--radius-sm:0.5rem;--radius:0.625rem;--radius-md:0.875rem;--radius-lg:1.125rem;--radius-xl:1.5rem;--radius-full:9999px;--nav-height:68px;--nav-bg:rgba(15,23,42,0.75);--card:var(--glass-bg);--surface-solid:#0F172A;--bg-gradient:linear-gradient(170deg,#0a1628 0%,#0F172A 20%,#152240 50%,#1a2d5a 80%,#0F172A 100%);--accent-glow:rgba(59,130,246,0.12);--section-heading:#FFF;--muted:#94a3b8;--text-color:#FFF;--bg:#0F172A;--surface-strong:#32353c;--ghost-border:rgba(255,255,255,.12);--bg-gradient:linear-gradient(170deg,#0a1628 0%,#0F172A 25%,#152240 55%,#1a2d5a 100%)}html.theme-light{--surface:#f1f5f9;--surface-dim:#d6dae4;--surface-container-high:#d8dce6;--surface-container-highest:#ccd0dc;--on-surface:#0F172A;--on-surface-variant:#475569;--glass-bg:rgba(255,255,255,0.7);--glass-border:rgba(15,23,42,0.1);--nav-bg:rgba(255,255,255,0.8);--border:rgba(15,23,42,0.1);--ghost-border:rgba(15,23,42,0.12);--card:var(--glass-bg);--surface-solid:#FFF;--bg-gradient:linear-gradient(170deg,#f8faff 0%,#ffffff 30%,#f0f6ff 65%,#e8f0fe 100%);--section-heading:#0F172A;--muted:#64748b;--text-color:#0F172A;--bg:#FFF;--surface-strong:#ccd0dc;--ghost-border:rgba(15,23,42,.12)}*,::after,::before{box-sizing:border-box;margin:0;padding:0}body,html{min-height:100%}body{font-family:var(--font-body);color:var(--text-color);background:var(--bg-gradient);background-attachment:fixed;-webkit-font-smoothing:antialiased}.container{width:min(100% - 32px,1280px);margin:0 auto;padding:30px 0}.nav{position:sticky;top:0;z-index:20;border-bottom:1px solid transparent;background:var(--nav-bg);-webkit-backdrop-filter:blur(16px);backdrop-filter:blur(16px)}.nav.shrink{border-bottom-color:var(--glass-border);background:rgba(15,23,42,.85);-webkit-backdrop-filter:blur(20px);backdrop-filter:blur(20px)}.nav-inner{width:min(100% - 28px,1280px);min-height:var(--nav-height);margin:0 auto;display:flex;align-items:center;gap:14px}.brand{display:inline-flex;align-items:center;gap:12px;color:var(--text-color);text-decoration:none;flex-shrink:0}.logo-img{width:46px;height:46px;display:block;object-fit:contain;border-radius:50%;background:rgba(30,41,59,0.5);box-shadow:0 0 12px rgba(59,130,246,0.1)}.nav-links{margin:0 0 0 auto;padding:0;list-style:none;display:flex;align-items:center;gap:4px}.nav-links a{display:inline-flex;align-items:center;gap:6px;min-height:38px;padding:8px 12px;border-radius:var(--radius);color:var(--on-surface-variant);font-weight:500;font-size:.9rem;white-space:nowrap;position:relative}.nav-links a:hover,.nav-links a:focus-visible{color:var(--on-surface);background:rgba(59,130,246,0.08)}.nav-links a.active{color:var(--on-surface);background:rgba(59,130,246,0.06)}.nav-links a.active::after{content:'';position:absolute;bottom:2px;left:12px;right:12px;height:2px;background:var(--electric-blue);border-radius:var(--radius-full);box-shadow:0 0 10px rgba(59,130,246,0.5)}.nav-toggle{display:none}.theme-toggle{order:4;min-height:38px;margin-left:8px;padding:7px 12px;border-radius:var(--radius);font-size:.88rem;font-weight:600;border:1px solid var(--glass-border);color:var(--on-surface);background:var(--glass-bg);cursor:pointer;flex-shrink:0}.nav-date{display:inline-flex;align-items:center;gap:6px;padding:0 10px;border:1px solid var(--glass-border);border-radius:var(--radius);min-height:38px;background:var(--glass-bg);color:var(--on-surface-variant);font-weight:500;font-size:.82rem;white-space:nowrap;flex-shrink:0}.section{margin:28px 0;padding:clamp(26px,5vw,48px);border-radius:var(--radius-md);border:1px solid var(--glass-border);background:var(--glass-bg);-webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px)}.reveal{opacity:0;transform:translateY(18px);transition:opacity .6s,transform .6s}.reveal.active{opacity:1;transform:none}body.page-is-ready{animation:page-in 440ms ease both}@keyframes page-in{0%{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}.modern-hero{position:relative;min-height:calc(100vh - var(--nav-height) - 60px);display:grid;place-items:center;overflow:hidden}.hero-overlay{position:absolute;inset:0;pointer-events:none}.hero-content{position:relative;z-index:1;width:min(100%,780px);padding:24px 0;text-align:center}#home .hero-content{padding:0}#home .hero-card{background:var(--glass-bg);-webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px);border:1px solid var(--glass-border);box-shadow:var(--elevation-md),0 0 40px rgba(59,130,246,0.08);width:100%;max-width:780px;padding:clamp(22px,4vw,38px);border-radius:var(--radius-xl);display:grid;gap:14px;min-height:260px}#home .hero-logo-wrap{display:grid;gap:10px;justify-items:center}.logo-title{margin:0;font-family:var(--font-display);font-size:clamp(2rem,7vw,4.6rem);line-height:1;letter-spacing:-0.015em;font-weight:800;color:var(--section-heading);text-shadow:0 0 40px rgba(59,130,246,0.15)}.lead{max-width:720px;margin:0;color:var(--muted);line-height:1.75}.hero-ctas{display:flex;flex-wrap:wrap;align-items:center;gap:10px;justify-content:center}.btn{display:inline-flex;min-height:42px;align-items:center;justify-content:center;gap:8px;border:1px solid var(--glass-border);border-radius:var(--radius-md);padding:10px 18px;color:var(--on-surface);background:var(--glass-bg);-webkit-backdrop-filter:blur(8px);backdrop-filter:blur(8px);font-weight:500;text-decoration:none;cursor:pointer;transition:background .18s,transform .18s,box-shadow .18s,border-color .18s}.btn.primary{color:#fff;background:var(--electric-blue);border-color:transparent;box-shadow:0 0 20px rgba(59,130,246,0.2)}.btn.ghost{color:var(--on-surface-variant);background:transparent;border-color:var(--glass-border);box-shadow:none}.btn.ghost:hover{color:var(--on-surface);border-color:rgba(59,130,246,0.3);background:rgba(59,130,246,.08)}.btn:hover,.btn.primary:hover{transform:translateY(-1px)}.btn:active{transform:translateY(0)}#home .hero-logo-img{border-radius:50%;filter:drop-shadow(0 0 12px rgba(59,130,246,.35))}@media(max-width:620px){.modern-hero{min-height:calc(100vh - var(--nav-height) - 36px)}:root{--nav-height:64px}.container{width:min(100% - 20px,1280px);padding:18px 0}.btn{width:100%}.hero-ctas{flex-direction:column;align-items:stretch}}</style>

    <!-- Full stylesheet (non-critical) loaded asynchronously -->
    <link rel="stylesheet" href="/css/style.min.css" media="print" onload="this.media='all';this.onload=null">
    <noscript><link rel="stylesheet" href="/css/style.min.css"></noscript>

    <!-- Google Fonts for Deep Ocean typography -->

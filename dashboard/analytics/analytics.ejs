<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Analytics — Dev Console</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
  <%- include('_critical-css') %>
  <link rel="stylesheet" href="/dashboard-assets/shared/base.css">
  <link rel="stylesheet" href="/dashboard-assets/analytics/analytics.css">

  <!-- Vercel Analytics -->
  <script>window.va=window.va||function(){(window.vaq=window.vaq||[]).push(arguments)};</script>
  <script defer src="/_vercel/insights/script.js"></script>
  <script defer src="https://unpkg.com/@vercel/speed-insights/dist/index.js"></script>
</head>
<body>

  <div class="dash-shell">
    <%- include('_sidebar', { active: 'analytics' }) %>

    <div class="main">
      <header class="topbar">
        <div class="topbar-heading">
          <button class="hamburger" onclick="toggleSidebar()" aria-label="Toggle sidebar">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
          <h1>Analytics</h1>
          <p>Traffic, page views &amp; visitor behaviour.</p>
        </div>
        <div class="topbar-actions">
          <div class="online-badge">
            <span class="online-dot"></span>
            <span id="online-count"><%= pvStats ? pvStats.online : 0 %></span> online
          </div>
          <select class="select-btn" id="range-select" onchange="changeRange(this.value)">
            <option value="24h" <%- timeRange === '24h' ? 'selected' : '' %>>Last 24 Hours</option>
            <option value="7d"  <%- timeRange === '7d'  ? 'selected' : '' %>>Last 7 Days</option>
            <option value="30d" <%- timeRange === '30d' ? 'selected' : '' %>>Last 30 Days</option>
          </select>
          <button class="btn" onclick="refreshData()" title="Refresh data">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
            Refresh
          </button>
        </div>
      </header>

      <main class="content">

        <div class="refresh-row">
          <span class="refresh-dot"></span>
          <span class="refresh-label">Auto-refresh every 30s &bull; <span id="last-refreshed">Live</span></span>
        </div>

        <div class="stat-grid" id="metrics-row">
          <div class="stat-card active" id="card-visitors">
            <div class="stat-label">Visitors</div>
            <div class="stat-value" id="val-visitors"><%= pvStats ? pvStats.visitors : 0 %></div>
          </div>
          <div class="stat-card" id="card-pageviews">
            <div class="stat-label">Page Views</div>
            <div class="stat-value" id="val-pageviews"><%= pvStats ? pvStats.pageviews : 0 %></div>
          </div>
          <div class="stat-card" id="card-bounce">
            <div class="stat-label">Bounce Rate</div>
            <div class="stat-value">
              <span id="val-bounce"><%= pvStats ? pvStats.bounceRate : 0 %>%</span>
            </div>
          </div>
          <div class="stat-card" id="card-latency">
            <div class="stat-label">Avg Latency</div>
            <div class="stat-value" id="val-latency"><%= avgLatencyMs %>ms</div>
          </div>
        </div>

        <div class="card chart-wrap">
          <div class="chart-canvas-wrap">
            <canvas id="traffic-chart"></canvas>
          </div>
        </div>

      </main>
    </div>
  </div>

  <script>
  (function() {
    const chartData = <%- JSON.stringify(pvStats ? pvStats.chartData : {}) %>;
    const labels = Object.keys(chartData);
    const values = Object.values(chartData);

    const ctx = document.getElementById('traffic-chart').getContext('2d');
    const gradient = ctx.createLinearGradient(0, 0, 0, 240);
    gradient.addColorStop(0, 'rgba(59,130,246,0.18)');
    gradient.addColorStop(1, 'rgba(59,130,246,0.00)');

    const chart = new Chart(ctx, {
      type: 'line',
      data: {
        labels,
        datasets: [{
          label: 'Visitors',
          data: values,
          borderColor: '#3B82F6',
          borderWidth: 2,
          backgroundColor: gradient,
          fill: true,
          tension: 0.35,
          pointRadius: 0,
          pointHoverRadius: 5,
          pointHoverBackgroundColor: '#3B82F6',
          pointHoverBorderColor: '#fff',
          pointHoverBorderWidth: 2,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#0F172A',
            borderColor: 'rgba(15,23,42,0.1)',
            borderWidth: 1,
            titleColor: '#94A3B8',
            bodyColor: '#fff',
            padding: 10,
            cornerRadius: 8,
            callbacks: {
              title: (items) => items[0] ? items[0].label : '',
              label: (item) => ` Visitors  ${item.parsed.y}`
            }
          }
        },
        scales: {
          x: {
            grid: { color: '#EDF1F7', drawBorder: false },
            ticks: { color: '#94A3B8', font: { size: 11 }, maxTicksLimit: 8, maxRotation: 0 }
          },
          y: {
            beginAtZero: true,
            grid: { color: '#EDF1F7', drawBorder: false },
            ticks: { color: '#94A3B8', font: { size: 11 }, stepSize: 1, precision: 0 }
          }
        }
      }
    });

    window.changeRange = function(val) {
      window.location.href = '/dev/dashboard-desktop/analytics?range=' + val;
    };

    let currentRange = '<%= timeRange %>';

    window.refreshData = async function() {
      try {
        const res = await fetch('/api/dev/stats?range=' + currentRange);
        if (!res.ok) return;
        const json = await res.json();
        const pv = json.pvStats;
        const m  = json.metrics;

        document.getElementById('val-visitors').textContent  = pv.visitors;
        document.getElementById('val-pageviews').textContent = pv.pageviews;
        document.getElementById('val-bounce').textContent    = pv.bounceRate + '%';
        document.getElementById('val-latency').textContent   = m.avgLatencyMs + 'ms';
        document.getElementById('online-count').textContent  = pv.online;

        const newLabels = Object.keys(pv.chartData);
        const newValues = Object.values(pv.chartData);
        chart.data.labels = newLabels;
        chart.data.datasets[0].data = newValues;
        chart.update('active');

        const now = new Date();
        document.getElementById('last-refreshed').textContent =
          'Updated ' + String(now.getHours()).padStart(2,'0') + ':' +
          String(now.getMinutes()).padStart(2,'0') + ':' +
          String(now.getSeconds()).padStart(2,'0');
      } catch (e) {
        console.warn('[analytics] refresh error', e);
      }
    };

    setInterval(window.refreshData, 30000);

    document.querySelectorAll('.stat-card').forEach(card => {
      card.addEventListener('click', () => {
        document.querySelectorAll('.stat-card').forEach(c => c.classList.remove('active'));
        card.classList.add('active');
      });
    });
  })();
  </script>

</body>
</html>

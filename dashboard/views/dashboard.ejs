<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Dashboard — Dev Console</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/dashboard-assets/css/base.css">
  <link rel="stylesheet" href="/dashboard-assets/css/dashboard.css">

  <!-- Vercel Analytics -->
  <script>window.va=window.va||function(){(window.vaq=window.vaq||[]).push(arguments)};</script>
  <script defer src="/_vercel/insights/script.js"></script>
  <script defer src="https://unpkg.com/@vercel/speed-insights/dist/index.js"></script>
</head>
<body>

  <div class="dash-shell">
    <%- include('_sidebar', { active: 'dashboard' }) %>

    <div class="main">
      <header class="topbar">
        <div class="topbar-heading">
          <h1>Dashboard</h1>
          <p>Ringkasan sistem dan kontrol cepat.</p>
        </div>
        <div class="topbar-actions">
          <div class="online-badge">
            <span class="online-dot"></span>
            <span id="db-online-count">0</span> online
          </div>
          <button class="btn btn-primary" onclick="dbRefreshNow()">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
            Refresh
          </button>
        </div>
      </header>

      <main class="content">

        <!-- ── STATUS BANNER ── -->
        <div class="db-banner" id="db-banner">
          <div class="db-banner-item">
            <span class="db-banner-dot ok" id="db-dot-website"></span>
            <span class="db-banner-label">Website</span>
            <span class="db-banner-val" id="db-val-website">Checking...</span>
          </div>
          <div class="db-banner-item">
            <span class="db-banner-dot ok" id="db-dot-db"></span>
            <span class="db-banner-label">Database</span>
            <span class="db-banner-val" id="db-val-db">Checking...</span>
          </div>
          <div class="db-banner-item">
            <span class="db-banner-dot" id="db-dot-si"></span>
            <span class="db-banner-label">Speed Insights</span>
            <span class="db-banner-val" id="db-val-si">Checking...</span>
          </div>
          <div class="db-banner-item">
            <span class="db-banner-dot" id="db-dot-mt"></span>
            <span class="db-banner-label">Maintenance</span>
            <span class="db-banner-val" id="db-val-mt">—</span>
          </div>
        </div>

        <!-- ── TOP STATS ── -->
        <div class="stat-grid">
          <div class="stat-card">
            <div class="stat-label">Visitors <span class="db-range-badge" id="db-range-label">7d</span></div>
            <div class="stat-value" id="db-stat-visitors">0</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Page Views</div>
            <div class="stat-value" id="db-stat-pageviews">0</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Avg Latency</div>
            <div class="stat-value" id="db-stat-latency">0ms</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Total Requests</div>
            <div class="stat-value" id="db-stat-requests">0</div>
          </div>
        </div>

        <!-- ── QUICK ACTION GRID ── -->
        <div class="section-header" style="margin-top:4px;border:none;padding:12px 0 8px;">
          <span>Quick Actions</span>
        </div>
        <div class="db-quick-grid">
          <a href="/dev/dashboard" class="db-quick-card">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0h6"/></svg>
            <span>Overview</span>
          </a>
          <a href="/dev/dashboard/analytics" class="db-quick-card">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18M7 16l4-4 4 4 4-4"/></svg>
            <span>Analytics</span>
          </a>
          <a href="/dev/dashboard/monitoring" class="db-quick-card">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            <span>Monitoring</span>
          </a>
          <a href="/dev/dashboard/admins" class="db-quick-card">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-1.13a4 4 0 10-4-4 4 4 0 004 4zm6 0a4 4 0 10-3-6.65"/></svg>
            <span>Admin Mgmt</span>
          </a>
          <a href="/dev/dashboard/health" class="db-quick-card">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
            <span>Health</span>
          </a>
          <a href="/dev/dashboard/security" class="db-quick-card">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>Security</span>
          </a>
        </div>

        <!-- ── ADMIN ONLINE / RECENT SECTION ── -->
        <div class="db-two-col">
          <div class="card">
            <div class="section-header">
              <span>Online Admins</span>
              <span class="sub" id="db-admin-count">0</span>
            </div>
            <div class="db-section-body" id="db-admin-list">
              <div class="db-loading">Loading...</div>
            </div>
          </div>
          <div class="card">
            <div class="section-header">
              <span>Server Info</span>
              <span class="sub">Real-time</span>
            </div>
            <div class="db-section-body db-server-info" id="db-server-info">
              <div class="db-loading">Loading...</div>
            </div>
          </div>
        </div>

      </main>
    </div>
  </div>

  <script>
  // ── HELPERS ──
  function fmtUptime(s) {
    if (s < 60) return s + 's';
    if (s < 3600) return Math.floor(s/60) + 'm ' + (s%60) + 's';
    return Math.floor(s/3600) + 'h ' + Math.floor((s%3600)/60) + 'm';
  }

  function setBanner(id, status, val) {
    const dot = document.getElementById('db-dot-' + id);
    const valEl = document.getElementById('db-val-' + id);
    if (dot) { dot.className = 'db-banner-dot ' + status; }
    if (valEl) valEl.textContent = val;
  }

  // ── MAIN REFRESH ──
  async function dbRefresh() {
    try {
      // Health
      const h = await (await fetch('/api/dev/health')).json();
      setBanner('website', h.website === 'ok' ? 'ok' : 'error', h.website === 'ok' ? 'Online' : 'Error');
      setBanner('db', h.db === 'ok' ? 'ok' : 'error', h.db === 'ok' ? h.dbPingMs + 'ms ping' : (h.dbError || 'Disconnected'));

      // Server info
      document.getElementById('db-server-info').innerHTML =
        `<div class="db-si-row"><span>Uptime</span><span>${fmtUptime(h.uptimeSeconds || 0)}</span></div>
         <div class="db-si-row"><span>Memory</span><span>${h.memHeapUsedMB || 0} MB / ${h.memHeapTotalMB || 0} MB</span></div>
         <div class="db-si-row"><span>Node</span><span>${h.nodeVersion || '—'}</span></div>
         <div class="db-si-row"><span>Platform</span><span>${h.platform || '—'}</span></div>
         <div class="db-si-row"><span>DB Ping</span><span>${h.dbPingMs || 0}ms</span></div>`;
      document.getElementById('db-stat-requests').textContent = h.totalRequests || 0;

      // Stats
      const stats = await (await fetch('/api/dev/stats')).json();
      const pv = stats.pvStats || {};
      document.getElementById('db-online-count').textContent = pv.online || 0;
      document.getElementById('db-stat-visitors').textContent = pv.visitors || 0;
      document.getElementById('db-stat-pageviews').textContent = pv.pageviews || 0;
      document.getElementById('db-stat-latency').textContent = (stats.metrics ? (stats.metrics.avgLatencyMs || 0) : 0) + 'ms';

      // Admin statuses
      const adminsRes = await fetch('/dev/api/admins/statuses');
      const adminsData = await adminsRes.json();
      const statuses = adminsData.adminStatuses || {};
      const admins = adminsData.admins || [];
      const onlineAdmins = admins.filter(a => statuses[a.username] && statuses[a.username].online === true);
      document.getElementById('db-admin-count').textContent = onlineAdmins.length + '/' + admins.length + ' online';
      
      if (onlineAdmins.length === 0) {
        document.getElementById('db-admin-list').innerHTML = '<div class="db-empty" style="padding:16px;color:var(--muted);text-align:center;">Tidak ada admin online saat ini.</div>';
      } else {
        let html = '';
        onlineAdmins.forEach(a => {
          const st = statuses[a.username] || {};
          const last = st.lastOnline ? new Date(st.lastOnline).toLocaleString('id-ID') : '—';
          html += `<div class="db-admin-row">
            <span class="db-admin-dot"></span>
            <span class="db-admin-name">${a.username}</span>
            <span class="db-admin-last">${last}</span>
          </div>`;
        });
        document.getElementById('db-admin-list').innerHTML = html;
      }

      // Speed Insights status
      const siRes = await fetch('/api/dev/speed-insights/status');
      const siStatus = await siRes.json();
      setBanner('si', siStatus.configured ? 'ok' : 'warn', siStatus.configured ? 'Configured' : 'Not set up');
      if (siStatus.configured) {
        document.getElementById('db-dot-si').className = 'db-banner-dot ok';
      } else {
        document.getElementById('db-dot-si').className = 'db-banner-dot warn';
      }

      // Maintenance
      const mtRes = await fetch('/api/dev/maintenance/status');
      const mt = await mtRes.json();
      setBanner('mt', mt.enabled ? 'warn' : 'ok', mt.enabled ? 'ACTIVE' : 'Inactive');
    } catch (e) {
      console.warn('[dashboard] refresh error', e);
    }
  }

  window.dbRefreshNow = function() { dbRefresh(); };

  dbRefresh();
  setInterval(dbRefresh, 30000);
  </script>

</body>
</html>
<!-- ============================================================
     SIDEBAR — included by every dashboard page.
     Expects local var `active` = 'dashboard' | 'overview' | 'analytics' | 'monitoring' | 'admins'
                                  | 'health' | 'maintenance' | 'security'
     ============================================================ -->
<aside class="sidebar">

  <a class="sidebar-logo" href="/dev/dashboard">
    <span class="sidebar-logo-icon">G</span>
    <span class="sidebar-logo-text">
      <strong>Dev Console</strong>
      <span>gpieluzaikids.vercel.app</span>
    </span>
  </a>

  <nav class="sidebar-nav">

    <a class="sidebar-link <%= active === 'overview' ? 'active' : '' %>" href="/dev/dashboard">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0h6"/>
      </svg>
      Overview
    </a>

    <a class="sidebar-link <%= active === 'analytics' ? 'active' : '' %>" href="/dev/dashboard/analytics">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18M7 16l4-4 4 4 4-4"/>
      </svg>
      Analytics
    </a>

    <a class="sidebar-link <%= active === 'monitoring' ? 'active' : '' %>" href="/dev/dashboard/monitoring">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
      </svg>
      Monitoring
    </a>

    <a class="sidebar-link <%= active === 'admins' ? 'active' : '' %>" href="/dev/dashboard/admins">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-1.13a4 4 0 10-4-4 4 4 0 004 4zm6 0a4 4 0 10-3-6.65"/>
      </svg>
      Admins
    </a>

    <div class="sidebar-divider"></div>
    <div class="sidebar-section-label">System</div>

    <a class="sidebar-link <%= active === 'health' ? 'active' : '' %>" href="/dev/dashboard/health">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
      </svg>
      Health Check
    </a>

    <a class="sidebar-link <%= active === 'maintenance' ? 'active' : '' %>" href="/dev/dashboard/maintenance">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      Maintenance
      <span id="sidebar-mt-badge" class="sidebar-badge" style="display:none;">ON</span>
    </a>

    <a class="sidebar-link <%= active === 'security' ? 'active' : '' %>" href="/dev/dashboard/security">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
      Security
    </a>

  </nav>

  <div class="sidebar-footer">
    <div class="sidebar-panel">
      <div class="sidebar-panel-title"><span class="dot"></span>Dev Access</div>
      <div class="sidebar-panel-sub">Logged in as developer</div>
    </div>
    <a class="sidebar-signout" href="/dev/logout">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
      </svg>
      Sign Out
    </a>
  </div>

</aside>

<script>
// Show "ON" badge on Maintenance link when maintenance is active
(async function() {
  try {
    const res = await fetch('/api/dev/maintenance/status');
    if (!res.ok) return;
    const data = await res.json();
    const badge = document.getElementById('sidebar-mt-badge');
    if (badge && data.enabled) badge.style.display = 'inline-flex';
  } catch (_) {}
})();
</script>

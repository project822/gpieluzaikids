<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover">
  <title>Dev Console</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Hanken+Grotesk:wght@700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/dashboard-assets/css/mobile.css">
  <script>window.va=window.va||function(){(window.vaq=window.vaq||[]).push(arguments)};</script>
  <script defer src="/_vercel/insights/script.js"></script>
</head>
<body>

  <!-- ═══════════ HEADER ═══════════ -->
  <header class="mh">
    <div class="mh-top">
      <div class="mh-brand">
        <span class="mh-brand-icon">G</span>
        <div class="mh-brand-text">
          <strong>Dev Console</strong>
          <span>gpieluzaikids.vercel.app</span>
        </div>
      </div>
      <div class="mh-actions">
        <button class="mh-btn" onclick="mobRefresh()" aria-label="Refresh">
          <svg id="ri" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
        </button>
        <a href="/dev/logout" class="mh-btn mh-logout" aria-label="Sign Out">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        </a>
      </div>
    </div>
    <div class="mh-status" id="mh-status">
      <span class="mh-dot ok" id="md-website"></span><span id="ml-website">Online</span>
      <span class="mh-div"></span>
      <span class="mh-dot" id="md-db"></span><span id="ml-db">DB: ---</span>
      <span class="mh-div"></span>
      <span class="mh-dot" id="md-si"></span><span id="ml-si">SI: --</span>
      <span class="mh-div"></span>
      <span class="mh-dot" id="md-mt"></span><span id="ml-mt">MT: --</span>
      <span class="mh-div"></span>
      <a href="/dev/dashboard?mobile=0" style="color:var(--text-var);text-decoration:none;margin-left:auto;">Desktop</a>
    </div>
  </header>

  <!-- ═══════════ CONTENT ═══════════ -->
  <main class="mc" id="mc">

    <!-- ── TAB: OVERVIEW ── -->
    <section class="mt active" id="t-overview">

      <div class="mob">
        <span class="mob-dot"></span>
        <span>Visitors Online: <strong id="ov-online"><%= pvStats ? pvStats.online : 0 %></strong></span>
      </div>

      <!-- Stat grid -->
      <div class="mg">
        <div class="mgc">
          <div class="mgl">Visitors <span class="mgr">7d</span></div>
          <div class="mgv" id="ov-visitors"><%= pvStats ? pvStats.visitors : 0 %></div>
        </div>
        <div class="mgc">
          <div class="mgl">Page Views</div>
          <div class="mgv" id="ov-pageviews"><%= pvStats ? pvStats.pageviews : 0 %></div>
        </div>
        <div class="mgc">
          <div class="mgl">Latency</div>
          <div class="mgv" id="ov-latency"><%= avgLatencyMs %>ms</div>
        </div>
        <div class="mgc">
          <div class="mgl">Requests</div>
          <div class="mgv" id="ov-requests">0</div>
        </div>
      </div>

      <!-- System status -->
      <div class="msl">System Status</div>
      <div class="msgg">
        <div class="msgi" id="sc-website">
          <span class="msgi-dot ok"></span>
          <div class="msgi-bd"><div class="msgi-n">Website</div><div class="msgi-v" id="sv-website">Online</div></div>
          <span class="msgi-badge ok" id="sb-website">OK</span>
        </div>
        <div class="msgi" id="sc-db">
          <span class="msgi-dot" id="sd-db"></span>
          <div class="msgi-bd"><div class="msgi-n">Database</div><div class="msgi-v" id="sv-db">Checking...</div></div>
          <span class="msgi-badge" id="sb-db">---</span>
        </div>
        <div class="msgi" id="sc-mt">
          <span class="msgi-dot" id="sd-mt"></span>
          <div class="msgi-bd"><div class="msgi-n">Maintenance</div><div class="msgi-v" id="sv-mt">Inactive</div></div>
          <label class="mtog"><input type="checkbox" id="mt-toggle" onchange="mobToggleMt(this.checked)"><span class="mtog-tr"></span></label>
        </div>
        <div class="msgi">
          <span class="msgi-dot ok"></span>
          <div class="msgi-bd"><div class="msgi-n">Admins Online</div><div class="msgi-v" id="ov-admin-cnt">0/0</div></div>
          <span class="msgi-badge ok" id="ov-admin-badge">---</span>
        </div>
      </div>

      <div class="msl">Online Admins</div>
      <div class="mcd" id="ov-admin-list"><div class="mld">Loading...</div></div>

      <div class="msl">Server</div>
      <div class="mcd" id="ov-server"><div class="mld">Loading...</div></div>

    </section>

    <!-- ── TAB: ANALYTICS ── -->
    <section class="mt" id="t-analytics">

      <div class="msl">Traffic Overview</div>
      <div class="mg">
        <div class="mgc"><div class="mgl">Visitors <span class="mgr">7d</span></div><div class="mgv" id="an-visitors"><%= pvStats ? pvStats.visitors : 0 %></div></div>
        <div class="mgc"><div class="mgl">Page Views</div><div class="mgv" id="an-pageviews"><%= pvStats ? pvStats.pageviews : 0 %></div></div>
        <div class="mgc"><div class="mgl">Avg Latency</div><div class="mgv" id="an-latency"><%= avgLatencyMs %>ms</div></div>
        <div class="mgc"><div class="mgl">Online Now</div><div class="mgv" id="an-online"><%= pvStats ? pvStats.online : 0 %></div></div>
      </div>

      <div class="msl">Web Vitals</div>
      <div class="mcd" id="an-vitals">
        <div class="mld" id="an-vl">Loading Web Vitals...</div>
        <div class="mmt" id="an-ve" style="display:none;">⚠ Not configured</div>
        <div id="an-vd" style="display:none;">
          <div class="mvr" id="an-vr"></div>
          <div class="mssc">
            <div class="mssh"><span>Performance Score</span><span class="mssn" id="an-sc">--</span></div>
            <div class="msst"><div class="mssf" id="an-sf" style="width:0%"></div></div>
          </div>
        </div>
      </div>

    </section>

    <!-- ── TAB: MONITORING ── -->
    <section class="mt" id="t-monitoring">

      <div class="msl">Speed Insights</div>
      <div class="mcd" id="mon-vitals">
        <div class="mld" id="mon-vl">Loading...</div>
        <div class="mmt" id="mon-ve" style="display:none;">⚠ Not configured</div>
        <div id="mon-vd" style="display:none;">
          <div class="mvr" id="mon-vr"></div>
          <div class="mssc">
            <div class="mssh"><span>Performance</span><span class="mssn" id="mon-sc">--</span></div>
            <div class="msst"><div class="mssf" id="mon-sf" style="width:0%"></div></div>
          </div>
        </div>
      </div>

      <div class="msl">Server Metrics</div>
      <div class="mcd">
        <div class="mml">
          <div class="mmi"><span class="mmk">Uptime</span><span class="mmv" id="mon-uptime">---</span></div>
          <div class="mmi"><span class="mmk">Memory</span><span class="mmv" id="mon-mem">---</span></div>
          <div class="mmi"><span class="mmk">Node</span><span class="mmv" id="mon-node">---</span></div>
          <div class="mmi"><span class="mmk">Platform</span><span class="mmv" id="mon-plat">---</span></div>
          <div class="mmi"><span class="mmk">DB Ping</span><span class="mmv" id="mon-dbping">---</span></div>
          <div class="mmi"><span class="mmk">Requests</span><span class="mmv" id="mon-req">0</span></div>
        </div>
      </div>

    </section>

    <!-- ── TAB: ADMINS ── -->
    <section class="mt" id="t-admins">

      <div class="msl">Admin Accounts</div>
      <div class="mcd" id="admins-list"><div class="mld">Loading admins...</div></div>

      <div class="msl">Quick Actions</div>
      <div class="mag">
        <button class="mab" onclick="mobShowAdd()">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
          <span>Add Admin</span>
        </button>
        <a href="/dev/dashboard/health" class="mab">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          <span>Health Check</span>
        </a>
        <a href="/dev/dashboard/security" class="mab">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>Security</span>
        </a>
        <a href="/dev/dashboard/maintenance" class="mab">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <span>Maintenance</span>
        </a>
      </div>

    </section>

  </main>

  <!-- ═══════════ BOTTOM TAB BAR ═══════════ -->
  <nav class="mtb">
    <button class="mtbi active" data-tab="overview" onclick="mobTab('overview')">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0h6"/></svg>
      <span>Overview</span>
    </button>
    <button class="mtbi" data-tab="analytics" onclick="mobTab('analytics')">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18M7 16l4-4 4 4 4-4"/></svg>
      <span>Analytics</span>
    </button>
    <button class="mtbi" data-tab="monitoring" onclick="mobTab('monitoring')">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      <span>Monitor</span>
    </button>
    <button class="mtbi" data-tab="admins" onclick="mobTab('admins')">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-1.13a4 4 0 10-4-4 4 4 0 004 4zm6 0a4 4 0 10-3-6.65"/></svg>
      <span>Admins</span>
    </button>
  </nav>

  <!-- ═══════════ ADD ADMIN MODAL ═══════════ -->
  <div class="mmo" id="add-modal">
    <div class="mm">
      <div class="mmh">
        <h3>Add Admin</h3>
        <button class="mm-x" onclick="mobCloseModal()">&times;</button>
      </div>
      <div class="mmb">
        <div class="mme err" id="add-err"></div>
        <div class="mme ok" id="add-ok"></div>
        <div class="mf">
          <label>Username</label>
          <input type="text" id="add-user" placeholder="Enter username" autocomplete="off">
        </div>
        <div class="mf">
          <label>Password</label>
          <input type="password" id="add-pass" placeholder="Enter password">
        </div>
        <button class="mbtn mbtn-p" onclick="mobAddAdmin()">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
          Create Admin
        </button>
      </div>
    </div>
  </div>

  <!-- ═══════════ TOAST ═══════════ -->
  <div class="mtoast" id="toast"></div>

  <!-- ═══════════ JAVASCRIPT ═══════════ -->
  <script>
  // ── HELPERS ──
  function fmtUptime(s) {
    if (s == null) return '---';
    if (s < 60) return Math.round(s) + 's';
    if (s < 3600) return Math.floor(s/60) + 'm ' + Math.round(s%60) + 's';
    return Math.floor(s/3600) + 'h ' + Math.floor((s%3600)/60) + 'm';
  }

  function siColor(v, m) {
    if (v == null) return '#94A3B8';
    var t = {lcp:{good:2500,poor:4000},fcp:{good:1800,poor:3000},ttfb:{good:800,poor:1800},cls:{good:0.1,poor:0.25},inp:{good:200,poor:500}}[m];
    if (!t) return '#94A3B8';
    return v <= t.good ? '#16A34A' : v <= t.poor ? '#D97706' : '#DC2626';
  }

  function calcScore(paths) {
    if (!paths||!paths.length) return null;
    var th = {lcp:{good:2500,poor:4000},fcp:{good:1800,poor:3000},ttfb:{good:800,poor:1800},cls:{good:0.1,poor:0.25},inp:{good:200,poor:500}};
    var w = {lcp:30,fcp:15,ttfb:20,cls:15,inp:20};
    var tw=0,ts=0;
    ['lcp','fcp','ttfb','cls','inp'].forEach(function(m){
      var v = paths.map(function(p){return p[m]&&p[m].median}).filter(function(v){return v!=null});
      if (!v.length) return;
      var avg = v.reduce(function(a,b){return a+b},0)/v.length, t=th[m];
      var sc = avg<=t.good?100:avg<=t.poor?Math.round(50+50*(1-(avg-t.good)/(t.poor-t.good))):Math.max(0,Math.round(50*(1-(avg-t.poor)/t.poor)));
      ts += sc*w[m]; tw += w[m];
    });
    return tw>0 ? Math.round(ts/tw) : null;
  }

  function showVitals(paths, prefix) {
    var metrics = [{key:'lcp',label:'LCP'},{key:'fcp',label:'FCP'},{key:'ttfb',label:'TTFB'},{key:'cls',label:'CLS',f:true},{key:'inp',label:'INP'}];
    var html = '';
    metrics.forEach(function(m){
      var v = paths.map(function(p){return p[m.key]&&p[m.key].median}).filter(function(v){return v!=null});
      if (!v.length) return;
      var avg = v.reduce(function(a,b){return a+b},0)/v.length;
      var disp = m.f ? avg.toFixed(3) : Math.round(avg)+'ms';
      html += '<div class="mvc" style="border-color:'+siColor(avg,m.key)+'40;">';
      html += '<span class="mvcl">'+m.label+'</span>';
      html += '<span class="mvcv" style="color:'+siColor(avg,m.key)+';">'+disp+'</span></div>';
    });
    document.getElementById(prefix+'-vr').innerHTML = html;
    var sc = calcScore(paths);
    if (sc !== null) {
      var f = document.getElementById(prefix+'-sf');
      f.style.width = sc+'%';
      f.style.background = sc>=90?'#16A34A':sc>=50?'#D97706':'#DC2626';
      document.getElementById(prefix+'-sc').textContent = sc;
      document.getElementById(prefix+'-sc').style.color = sc>=90?'#16A34A':sc>=50?'#D97706':'#DC2626';
    }
  }

  function toast(msg) {
    var t = document.getElementById('toast');
    t.textContent = msg; t.classList.add('show');
    clearTimeout(t._h); t._h = setTimeout(function(){t.classList.remove('show')},2500);
  }

  // ── TAB SWITCHING ──
  function mobTab(name) {
    document.querySelectorAll('.mt').forEach(function(t){t.classList.remove('active')});
    document.querySelectorAll('.mtbi').forEach(function(b){b.classList.remove('active')});
    document.getElementById('t-'+name).classList.add('active');
    document.querySelector('.mtbi[data-tab="'+name+'"]').classList.add('active');
  }

  // ── MODAL ──
  function mobShowAdd() {
    document.getElementById('add-err').classList.remove('show');
    document.getElementById('add-ok').classList.remove('show');
    document.getElementById('add-user').value = '';
    document.getElementById('add-pass').value = '';
    document.getElementById('add-modal').classList.add('active');
  }
  function mobCloseModal() { document.getElementById('add-modal').classList.remove('active'); }
  document.addEventListener('click',function(e){if(e.target.classList.contains('mmo'))e.target.classList.remove('active');});

  // ── REFRESH ──
  async function mobRefresh() {
    var ri = document.getElementById('ri');
    ri.classList.add('mh-spin');
    setTimeout(function(){ri.classList.remove('mh-spin')},600);

    try {
      // Health
      var h = await (await fetch('/api/dev/health')).json();

      function setDot(id, st) { var e=document.getElementById('md-'+id); if(e) e.className='mh-dot '+st; }
      function setLbl(id, v) { var e=document.getElementById('ml-'+id); if(e) e.textContent=v; }
      setDot('website',h.website==='ok'?'ok':'error'); setLbl('website',h.website==='ok'?'Online':'Error');
      setDot('db',h.db==='ok'?'ok':'error'); setLbl('db',h.db==='ok'?'DB: '+h.dbPingMs+'ms':'DB: Error');

      // Monitoring metrics
      document.getElementById('mon-uptime').textContent = fmtUptime(h.uptimeSeconds||0);
      document.getElementById('mon-mem').textContent = (h.memHeapUsedMB||0)+' MB / '+(h.memHeapTotalMB||0)+' MB';
      document.getElementById('mon-node').textContent = h.nodeVersion||'---';
      document.getElementById('mon-plat').textContent = h.platform||'---';
      document.getElementById('mon-dbping').textContent = (h.dbPingMs||0)+'ms';
      document.getElementById('mon-req').textContent = h.totalRequests||0;

      // Overview server
      var si = '<div class="msir"><span class="msik">Uptime</span><span class="msiv">'+fmtUptime(h.uptimeSeconds||0)+'</span></div>'+
        '<div class="msir"><span class="msik">Memory</span><span class="msiv">'+(h.memHeapUsedMB||0)+' MB / '+(h.memHeapTotalMB||0)+' MB</span></div>'+
        '<div class="msir"><span class="msik">Node</span><span class="msiv">'+(h.nodeVersion||'---')+'</span></div>'+
        '<div class="msir"><span class="msik">Platform</span><span class="msiv">'+(h.platform||'---')+'</span></div>'+
        '<div class="msir"><span class="msik">DB Ping</span><span class="msiv">'+(h.dbPingMs||0)+'ms</span></div>';
      document.getElementById('ov-server').innerHTML = si;

      // Overview status
      function setSt(id, st, badge, val) {
        var d = document.getElementById('sd-'+id);
        var b = document.getElementById('sb-'+id);
        var v = document.getElementById('sv-'+id);
        if(d) d.className='msgi-dot '+st;
        if(b){b.textContent=badge;b.className='msgi-badge '+st;}
        if(v) v.textContent=val;
      }
      setSt('website', h.website==='ok'?'ok':'error', h.website==='ok'?'Online':'Error', h.website==='ok'?'Online':'Degraded');
      setSt('db', h.db==='ok'?'ok':'error', h.db==='ok'?'Connected':'Error', h.db==='ok'?h.dbPingMs+'ms ping':(h.dbError||'Disconnected'));
      document.getElementById('ov-requests').textContent = h.totalRequests||0;

      // Stats
      var s = await (await fetch('/api/dev/stats')).json();
      var pv = s.pvStats||{};
      document.getElementById('ov-online').textContent = pv.online||0;
      document.getElementById('ov-visitors').textContent = pv.visitors||0;
      document.getElementById('ov-pageviews').textContent = pv.pageviews||0;
      document.getElementById('ov-latency').textContent = (s.metrics?(s.metrics.avgLatencyMs||0):0)+'ms';
      document.getElementById('an-visitors').textContent = pv.visitors||0;
      document.getElementById('an-pageviews').textContent = pv.pageviews||0;
      document.getElementById('an-latency').textContent = (s.metrics?(s.metrics.avgLatencyMs||0):0)+'ms';
      document.getElementById('an-online').textContent = pv.online||0;

      // Admins
      var a = await (await fetch('/dev/api/admins/statuses')).json();
      var sts = a.adminStatuses||{}, adms = a.admins||[];
      var online = adms.filter(function(a){return sts[a.username]&&sts[a.username].online===true});
      document.getElementById('ov-admin-cnt').textContent = online.length+'/'+adms.length;
      document.getElementById('ov-admin-badge').textContent = online.length+' online';

      if (!online.length) {
        document.getElementById('ov-admin-list').innerHTML = '<div class="mmt">Tidak ada admin online saat ini.</div>';
      } else {
        var htm = '';
        online.forEach(function(a){
          var st = sts[a.username]||{}, last = st.lastOnline?new Date(st.lastOnline).toLocaleString('id-ID'):'---';
          htm += '<div class="mar"><span class="mar-dot"></span><span class="mar-n">'+a.username+'</span><span class="mar-t">'+last+'</span></div>';
        });
        document.getElementById('ov-admin-list').innerHTML = htm;
      }

      // Admins tab list
      if (!adms.length) {
        document.getElementById('admins-list').innerHTML = '<div class="mmt">Belum ada admin.</div>';
      } else {
        var ah = '';
        adms.forEach(function(a){
          var st = sts[a.username]||{}, io = st.online===true, inl = a.username.charAt(0).toUpperCase();
          ah += '<div class="maa"><div class="maa-l"><div class="maa-av">'+inl+'</div><div class="maa-i"><span class="maa-n">'+a.username+'</span><span class="maa-s"><span style="width:5px;height:5px;border-radius:50%;background:'+(io?'#16A34A':'#64748B')+';display:inline-block;"></span> '+(io?'Online':'Offline')+'</span></div></div></div>';
        });
        document.getElementById('admins-list').innerHTML = ah;
      }

      // Speed Insights
      var siS = await (await fetch('/api/dev/speed-insights/status')).json();
      setDot('si', siS.configured?'ok':'warn'); setLbl('si', siS.configured?'SI: OK':'SI: --');
      if (siS.configured) {
        var siD = await (await fetch('/api/dev/speed-insights?range=7d')).json();
        if (siD.error||!siD.paths||!siD.paths.length) {
          document.getElementById('an-vl').style.display='none';
          document.getElementById('an-ve').style.display='block';
          document.getElementById('mon-vl').style.display='none';
          document.getElementById('mon-ve').style.display='block';
        } else {
          document.getElementById('an-vl').style.display='none';
          document.getElementById('an-vd').style.display='block';
          document.getElementById('mon-vl').style.display='none';
          document.getElementById('mon-vd').style.display='block';
          showVitals(siD.paths, 'an');
          showVitals(siD.paths, 'mon');
        }
      } else {
        document.getElementById('an-vl').style.display='none';
        document.getElementById('an-ve').style.display='block';
        document.getElementById('mon-vl').style.display='none';
        document.getElementById('mon-ve').style.display='block';
      }

      // Maintenance
      var mt = await (await fetch('/api/dev/maintenance/status')).json();
      setDot('mt', mt.enabled?'warn':'ok'); setLbl('mt', mt.enabled?'MT: ON':'MT: OFF');
      setSt('mt', mt.enabled?'warn':'ok', mt.enabled?'ACTIVE':'Inactive', mt.enabled?'ACTIVE':'Inactive');
      document.getElementById('mt-toggle').checked = mt.enabled===true;

    } catch(e) { console.warn('[mobile] refresh error',e); }
  }

  // ── MAINTENANCE TOGGLE ──
  async function mobToggleMt(enabled) {
    try {
      var r = await fetch('/api/dev/maintenance', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({enabled:enabled})});
      var d = await r.json();
      if (!d.ok) throw new Error(d.error);
      setDot('mt', enabled?'warn':'ok'); setLbl('mt', enabled?'MT: ON':'MT: OFF');
      toast(enabled?'Maintenance ACTIVE':'Maintenance OFF');
    } catch(e) { document.getElementById('mt-toggle').checked = !enabled; toast('Error: '+e.message); }
  }

  // ── ADD ADMIN ──
  async function mobAddAdmin() {
    var err = document.getElementById('add-err'), ok = document.getElementById('add-ok');
    err.classList.remove('show'); ok.classList.remove('show');
    var user = document.getElementById('add-user').value.trim(), pass = document.getElementById('add-pass').value;
    if (!user||!pass) { err.textContent='Wajib diisi'; err.classList.add('show'); return; }
    try {
      var r = await fetch('/dev/api/admins/add', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:user,password:pass})});
      var d = await r.json();
      if (d.error) { err.textContent=d.error; err.classList.add('show'); }
      else { ok.textContent='Admin "'+user+'" berhasil!'; ok.classList.add('show'); document.getElementById('add-user').value=''; document.getElementById('add-pass').value=''; toast('Admin created'); mobRefresh(); }
    } catch(e) { err.textContent='Error: '+e.message; err.classList.add('show'); }
  }

  // ── INIT ──
  mobRefresh();
  setInterval(mobRefresh, 30000);
  </script>

</body>
</html>
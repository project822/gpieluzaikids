<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover">
  <title>Dev Console</title>
  <link rel="stylesheet" href="/dashboard-assets/css/mobile.css">
  <script>window.va=window.va||function(){(window.vaq=window.vaq||[]).push(arguments)};</script>
  <script defer src="/_vercel/insights/script.js"></script>
</head>
<body>

  <!-- ═══ HEADER ═══ -->
  <header class="app-header">
    <div class="app-header-inner">
      <div class="app-brand">
        <span class="app-brand-icon">G</span>
        <div class="app-brand-text">
          <strong>Dev Console</strong>
          <span>gpieluzaikids.vercel.app</span>
        </div>
      </div>
      <div class="app-header-actions">
        <button class="app-btn" onclick="mobRefresh()" aria-label="Refresh">
          <svg id="ri" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
        </button>
        <a href="/dev/logout" class="app-btn" aria-label="Sign Out">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        </a>
      </div>
    </div>
    <div class="app-status">
      <span class="status-dot online" id="md-website"></span><span id="ml-website">Website</span>
      <span class="status-divider"></span>
      <span class="status-dot" id="md-db"></span><span id="ml-db">DB</span>
      <span class="status-divider"></span>
      <span class="status-dot" id="md-si"></span><span id="ml-si">SI</span>
      <span class="status-divider"></span>
      <span class="status-dot" id="md-mt"></span><span id="ml-mt">MT</span>
      <a href="/dev/dashboard?mobile=0" class="status-link">Desktop ↗</a>
    </div>
  </header>

  <!-- ═══ CONTENT ═══ -->
  <main class="app-content" id="app-content">

    <!-- ─────── TAB: OVERVIEW ─────── -->
    <section class="app-tab active" id="t-overview">

      <div class="online-banner">
        <span class="online-banner-dot"></span>
        <span>Visitors Online: <strong id="ov-online"><%= pvStats ? pvStats.online : 0 %></strong></span>
      </div>

      <div class="stat-grid">
        <div class="stat-card">
          <div class="stat-card-label">Visitors <span class="stat-card-badge">7d</span></div>
          <div class="stat-card-value" id="ov-visitors"><%= pvStats ? pvStats.visitors : 0 %></div>
        </div>
        <div class="stat-card">
          <div class="stat-card-label">Page Views</div>
          <div class="stat-card-value" id="ov-pageviews"><%= pvStats ? pvStats.pageviews : 0 %></div>
        </div>
        <div class="stat-card">
          <div class="stat-card-label">Latency</div>
          <div class="stat-card-value" id="ov-latency"><%= avgLatencyMs %>ms</div>
        </div>
        <div class="stat-card">
          <div class="stat-card-label">Requests</div>
          <div class="stat-card-value" id="ov-requests">0</div>
        </div>
      </div>

      <div class="section-title">System Status</div>

      <div class="status-grid">
        <div class="status-item" id="sc-website">
          <span class="status-item-dot online"></span>
          <div class="status-item-body">
            <div class="status-item-name">Website</div>
            <div class="status-item-value" id="sv-website">Online</div>
          </div>
          <span class="status-item-badge online" id="sb-website">OK</span>
        </div>
        <div class="status-item" id="sc-db">
          <span class="status-item-dot" id="sd-db"></span>
          <div class="status-item-body">
            <div class="status-item-name">Database</div>
            <div class="status-item-value" id="sv-db">Checking...</div>
          </div>
          <span class="status-item-badge" id="sb-db">---</span>
        </div>
        <div class="status-item" id="sc-mt">
          <span class="status-item-dot" id="sd-mt"></span>
          <div class="status-item-body">
            <div class="status-item-name">Maintenance</div>
            <div class="status-item-value" id="sv-mt">Inactive</div>
          </div>
          <label class="toggle"><input type="checkbox" id="mt-toggle" onchange="mobToggleMt(this.checked)"><span class="toggle-track"></span></label>
        </div>
        <div class="status-item">
          <span class="status-item-dot online"></span>
          <div class="status-item-body">
            <div class="status-item-name">Admins Online</div>
            <div class="status-item-value" id="ov-admin-cnt">0/0</div>
          </div>
          <span class="status-item-badge online" id="ov-admin-badge">---</span>
        </div>
      </div>

      <div class="section-title">Online Admins</div>
      <div class="app-card" id="ov-admin-list"><div class="app-card-loading">Loading...</div></div>

      <div class="section-title">Server</div>
      <div class="app-card" id="ov-server"><div class="app-card-loading">Loading...</div></div>

    </section>

    <!-- ─────── TAB: ANALYTICS ─────── -->
    <section class="app-tab" id="t-analytics">

      <div class="section-title">Traffic Overview</div>

      <div class="stat-grid">
        <div class="stat-card"><div class="stat-card-label">Visitors <span class="stat-card-badge">7d</span></div><div class="stat-card-value" id="an-visitors"><%= pvStats ? pvStats.visitors : 0 %></div></div>
        <div class="stat-card"><div class="stat-card-label">Page Views</div><div class="stat-card-value" id="an-pageviews"><%= pvStats ? pvStats.pageviews : 0 %></div></div>
        <div class="stat-card"><div class="stat-card-label">Avg Latency</div><div class="stat-card-value" id="an-latency"><%= avgLatencyMs %>ms</div></div>
        <div class="stat-card"><div class="stat-card-label">Online Now</div><div class="stat-card-value" id="an-online"><%= pvStats ? pvStats.online : 0 %></div></div>
      </div>

      <div class="section-title">Web Vitals</div>

      <div class="app-card" id="an-vitals">
        <div class="app-card-loading" id="an-vl">Loading Web Vitals...</div>
        <div class="app-card-empty" id="an-ve" style="display:none;">⚠ Speed Insights not configured</div>
        <div id="an-vd" style="display:none;">
          <div class="vitals-row" id="an-vr"></div>
          <div class="score-section">
            <div class="score-header"><span>Performance Score</span><span class="score-number" id="an-sc">--</span></div>
            <div class="score-track"><div class="score-fill" id="an-sf" style="width:0%"></div></div>
          </div>
        </div>
      </div>

    </section>

    <!-- ─────── TAB: MONITORING ─────── -->
    <section class="app-tab" id="t-monitoring">

      <div class="section-title">Speed Insights</div>

      <div class="app-card" id="mon-vitals">
        <div class="app-card-loading" id="mon-vl">Loading...</div>
        <div class="app-card-empty" id="mon-ve" style="display:none;">⚠ Not configured</div>
        <div id="mon-vd" style="display:none;">
          <div class="vitals-row" id="mon-vr"></div>
          <div class="score-section">
            <div class="score-header"><span>Performance</span><span class="score-number" id="mon-sc">--</span></div>
            <div class="score-track"><div class="score-fill" id="mon-sf" style="width:0%"></div></div>
          </div>
        </div>
      </div>

      <div class="section-title">Server Metrics</div>

      <div class="app-card">
        <div class="metrics-list">
          <div class="metric-row"><span class="metric-key">Uptime</span><span class="metric-value" id="mon-uptime">---</span></div>
          <div class="metric-row"><span class="metric-key">Memory</span><span class="metric-value" id="mon-mem">---</span></div>
          <div class="metric-row"><span class="metric-key">Node</span><span class="metric-value" id="mon-node">---</span></div>
          <div class="metric-row"><span class="metric-key">Platform</span><span class="metric-value" id="mon-plat">---</span></div>
          <div class="metric-row"><span class="metric-key">DB Ping</span><span class="metric-value" id="mon-dbping">---</span></div>
          <div class="metric-row"><span class="metric-key">Requests</span><span class="metric-value" id="mon-req">0</span></div>
        </div>
      </div>

    </section>

    <!-- ─────── TAB: ADMINS ─────── -->
    <section class="app-tab" id="t-admins">

      <div class="section-title">Admin Accounts</div>
      <div class="app-card" id="admins-list"><div class="app-card-loading">Loading admins...</div></div>

      <div class="section-title">Quick Actions</div>

      <div class="action-grid">
        <button class="action-btn" onclick="mobShowAdd()">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
          <span>Add Admin</span>
        </button>
        <a href="/dev/dashboard/health" class="action-btn">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          <span>Health Check</span>
        </a>
        <a href="/dev/dashboard/security" class="action-btn">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>Security</span>
        </a>
        <a href="/dev/dashboard/maintenance" class="action-btn">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <span>Maintenance</span>
        </a>
      </div>

    </section>

  </main>

  <!-- ═══ BOTTOM TAB BAR ═══ -->
  <nav class="app-tabbar">
    <button class="app-tabbar-item active" data-tab="overview" onclick="mobTab('overview')">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0h6"/></svg>
      <span>Overview</span>
    </button>
    <button class="app-tabbar-item" data-tab="analytics" onclick="mobTab('analytics')">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18M7 16l4-4 4 4 4-4"/></svg>
      <span>Analytics</span>
    </button>
    <button class="app-tabbar-item" data-tab="monitoring" onclick="mobTab('monitoring')">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      <span>Monitor</span>
    </button>
    <button class="app-tabbar-item" data-tab="admins" onclick="mobTab('admins')">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-1.13a4 4 0 10-4-4 4 4 0 004 4zm6 0a4 4 0 10-3-6.65"/></svg>
      <span>Admins</span>
    </button>
  </nav>

  <!-- ═══ ADD ADMIN MODAL ═══ -->
  <div class="modal-overlay" id="add-modal">
    <div class="modal-sheet">
      <div class="modal-sheet-header">
        <h3>Add Admin</h3>
        <button class="modal-sheet-close" onclick="mobCloseModal()">&times;</button>
      </div>
      <div class="modal-sheet-body">
        <div class="modal-message" id="add-err"></div>
        <div class="modal-message" id="add-ok"></div>
        <div class="form-field">
          <label>Username</label>
          <input type="text" id="add-user" placeholder="Enter username" autocomplete="off">
        </div>
        <div class="form-field">
          <label>Password</label>
          <input type="password" id="add-pass" placeholder="Enter password">
        </div>
        <button class="btn-primary" onclick="mobAddAdmin()">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
          Create Admin
        </button>
      </div>
    </div>
  </div>

  <!-- ═══ TOAST ═══ -->
  <div class="app-toast" id="toast"></div>

  <!-- ═══ JAVASCRIPT ═══ -->
  <script>
  var _ = document.getElementById.bind(document);

  function fmtU(s) {
    if (s == null) return '---';
    if (s < 60) return Math.round(s) + 's';
    if (s < 3600) return Math.floor(s/60) + 'm ' + Math.round(s%60) + 's';
    return Math.floor(s/3600) + 'h ' + Math.floor((s%3600)/60) + 'm';
  }

  function siC(v,m) {
    if (v==null) return '#94a3b8';
    var t={lcp:{g:2500,p:4000},fcp:{g:1800,p:3000},ttfb:{g:800,p:1800},cls:{g:0.1,p:0.25},inp:{g:200,p:500}}[m];
    return t ? (v<=t.g?'#22c55e':v<=t.p?'#f59e0b':'#ef4444') : '#94a3b8';
  }

  function calcSc(p) {
    if (!p||!p.length) return null;
    var th={lcp:{g:2500,p:4000},fcp:{g:1800,p:3000},ttfb:{g:800,p:1800},cls:{g:0.1,p:0.25},inp:{g:200,p:500}};
    var w={lcp:30,fcp:15,ttfb:20,cls:15,inp:20},tw=0,ts=0;
    ['lcp','fcp','ttfb','cls','inp'].forEach(function(m){
      var v=p.map(function(x){return x[m]&&x[m].median}).filter(function(x){return x!=null});
      if (!v.length) return;
      var a=v.reduce(function(a,b){return a+b},0)/v.length,t=th[m];
      var sc=a<=t.g?100:a<=t.p?Math.round(50+50*(1-(a-t.g)/(t.p-t.g))):Math.max(0,Math.round(50*(1-(a-t.p)/t.p)));
      ts+=sc*w[m];tw+=w[m];
    });
    return tw>0?Math.round(ts/tw):null;
  }

  function shV(p,pr) {
    var m=[{k:'lcp',l:'LCP'},{k:'fcp',l:'FCP'},{k:'ttfb',l:'TTFB'},{k:'cls',l:'CLS',f:true},{k:'inp',l:'INP'}];
    var h='';
    m.forEach(function(x){
      var v=p.map(function(y){return y[x.k]&&y[x.k].median}).filter(function(y){return y!=null});
      if (!v.length) return;
      var a=v.reduce(function(a,b){return a+b},0)/v.length, d=x.f?a.toFixed(3):Math.round(a)+'ms';
      h+='<div class="vital-chip" style="border-color:'+siC(a,x.k)+'40;"><span class="vital-chip-label">'+x.l+'</span><span class="vital-chip-value" style="color:'+siC(a,x.k)+';">'+d+'</span></div>';
    });
    _(pr+'-vr').innerHTML=h;
    var sc=calcSc(p);
    if (sc!==null) {
      var f=_(pr+'-sf'); f.style.width=sc+'%';
      f.style.background=sc>=90?'#22c55e':sc>=50?'#f59e0b':'#ef4444';
      _(pr+'-sc').textContent=sc;_(pr+'-sc').style.color=sc>=90?'#22c55e':sc>=50?'#f59e0b':'#ef4444';
    }
  }

  function toast(m) {
    var t=_('toast'); t.textContent=m; t.classList.add('show');
    clearTimeout(t._h); t._h=setTimeout(function(){t.classList.remove('show')},2500);
  }

  function mobTab(n) {
    document.querySelectorAll('.app-tab').forEach(function(t){t.classList.remove('active')});
    document.querySelectorAll('.app-tabbar-item').forEach(function(b){b.classList.remove('active')});
    _('t-'+n).classList.add('active');
    document.querySelector('.app-tabbar-item[data-tab="'+n+'"]').classList.add('active');
  }

  function mobShowAdd() {
    _('add-err').className='modal-message';_('add-ok').className='modal-message';
    _('add-user').value='';_('add-pass').value='';
    _('add-modal').classList.add('active');
  }
  function mobCloseModal(){_('add-modal').classList.remove('active');}
  document.addEventListener('click',function(e){if(e.target.classList.contains('modal-overlay')){e.target.classList.remove('active');}});

  function setDot(id,s){var e=_('md-'+id);if(e){e.className='status-dot '+s;}}
  function setLbl(id,v){var e=_('ml-'+id);if(e)e.textContent=v;}
  function setSt(id,s,badge,val){
    var d=_('sd-'+id),b=_('sb-'+id),v=_('sv-'+id);
    if(d)d.className='status-item-dot '+s;
    if(b){b.textContent=badge;b.className='status-item-badge '+s;}
    if(v)v.textContent=val;
  }

  async function mobRefresh() {
    var ri=_('ri'); ri.classList.add('app-btn-spin');
    setTimeout(function(){ri.classList.remove('app-btn-spin')},500);
    try {
      var h=await(await fetch('/api/dev/health')).json();
      setDot('website',h.website==='ok'?'online':'error');setLbl('website',h.website==='ok'?'Website ✓':'Error');
      setDot('db',h.db==='ok'?'online':'error');setLbl('db',h.db==='ok'?'DB '+h.dbPingMs+'ms':'DB ✗');
      _('mon-uptime').textContent=fmtU(h.uptimeSeconds||0);
      _('mon-mem').textContent=(h.memHeapUsedMB||0)+' MB';
      _('mon-node').textContent=h.nodeVersion||'---';
      _('mon-plat').textContent=h.platform||'---';
      _('mon-dbping').textContent=(h.dbPingMs||0)+'ms';
      _('mon-req').textContent=h.totalRequests||0;
      var si='<div class="server-row"><span class="server-row-key">Uptime</span><span class="server-row-value">'+fmtU(h.uptimeSeconds||0)+'</span></div>'+
        '<div class="server-row"><span class="server-row-key">Memory</span><span class="server-row-value">'+(h.memHeapUsedMB||0)+' MB</span></div>'+
        '<div class="server-row"><span class="server-row-key">Node</span><span class="server-row-value">'+(h.nodeVersion||'---')+'</span></div>'+
        '<div class="server-row"><span class="server-row-key">Platform</span><span class="server-row-value">'+(h.platform||'---')+'</span></div>'+
        '<div class="server-row"><span class="server-row-key">DB Ping</span><span class="server-row-value">'+(h.dbPingMs||0)+'ms</span></div>';
      _('ov-server').innerHTML=si;
      setSt('website',h.website==='ok'?'online':'error',h.website==='ok'?'Online':'Error',h.website==='ok'?'Online':'Degraded');
      setSt('db',h.db==='ok'?'online':'error',h.db==='ok'?'Connected':'Error',h.db==='ok'?h.dbPingMs+'ms':(h.dbError||'Disconnected'));
      _('ov-requests').textContent=h.totalRequests||0;

      var s=await(await fetch('/api/dev/stats')).json(),pv=s.pvStats||{};
      _('ov-online').textContent=pv.online||0;_('ov-visitors').textContent=pv.visitors||0;
      _('ov-pageviews').textContent=pv.pageviews||0;
      _('ov-latency').textContent=(s.metrics?(s.metrics.avgLatencyMs||0):0)+'ms';
      _('an-visitors').textContent=pv.visitors||0;_('an-pageviews').textContent=pv.pageviews||0;
      _('an-latency').textContent=(s.metrics?(s.metrics.avgLatencyMs||0):0)+'ms';
      _('an-online').textContent=pv.online||0;

      var a=await(await fetch('/dev/api/admins/statuses')).json();
      var sts=a.adminStatuses||{},adms=a.admins||[];
      var ol=adms.filter(function(x){return sts[x.username]&&sts[x.username].online===true});
      _('ov-admin-cnt').textContent=ol.length+'/'+adms.length;
      _('ov-admin-badge').textContent=ol.length+' online';
      _('ov-admin-list').innerHTML=!ol.length?'<div class="app-card-empty">No admins online</div>':
        ol.map(function(x){var s=sts[x.username]||{},l=s.lastOnline?new Date(s.lastOnline).toLocaleString('id-ID'):'---';
        return '<div class="admin-row"><span class="admin-row-dot"></span><span class="admin-row-name">'+x.username+'</span><span class="admin-row-time">'+l+'</span></div>';}).join('');

      _('admins-list').innerHTML=!adms.length?'<div class="app-card-empty">No admins</div>':
        adms.map(function(x){var s=sts[x.username]||{},io=s.online===true,inl=x.username.charAt(0).toUpperCase();
        return '<div class="account-item"><div class="account-item-left"><div class="account-item-avatar">'+inl+'</div><div class="account-item-info"><span class="account-item-name">'+x.username+'</span><span class="account-item-status"><span style="width:5px;height:5px;border-radius:50%;background:'+(io?'#22c55e':'#64748b')+';display:inline-block;"></span> '+(io?'Online':'Offline')+'</span></div></div></div>';}).join('');

      var siS=await(await fetch('/api/dev/speed-insights/status')).json();
      setDot('si',siS.configured?'online':'warn');setLbl('si',siS.configured?'SI ✓':'SI ⚠');
      if(siS.configured){
        var siD=await(await fetch('/api/dev/speed-insights?range=7d')).json();
        if(siD.error||!siD.paths||!siD.paths.length){
          _('an-vl').style.display='none';_('an-ve').style.display='block';
          _('mon-vl').style.display='none';_('mon-ve').style.display='block';
        }else{
          _('an-vl').style.display='none';_('an-vd').style.display='block';
          _('mon-vl').style.display='none';_('mon-vd').style.display='block';
          shV(siD.paths,'an');shV(siD.paths,'mon');
        }
      }else{
        _('an-vl').style.display='none';_('an-ve').style.display='block';
        _('mon-vl').style.display='none';_('mon-ve').style.display='block';
      }

      var mt=await(await fetch('/api/dev/maintenance/status')).json();
      setDot('mt',mt.enabled?'warn':'online');setLbl('mt',mt.enabled?'MT ON':'MT OFF');
      setSt('mt',mt.enabled?'warn':'online',mt.enabled?'Active':'Inactive',mt.enabled?'Active':'Inactive');
      _('mt-toggle').checked=mt.enabled===true;
    }catch(e){console.warn('[mobile]',e);}
  }

  async function mobToggleMt(e){
    try{
      var r=await fetch('/api/dev/maintenance',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({enabled:e})});
      var d=await r.json();if(!d.ok)throw new Error(d.error);
      setDot('mt',e?'warn':'online');setLbl('mt',e?'MT ON':'MT OFF');toast(e?'Maintenance ON':'Maintenance OFF');
    }catch(x){_('mt-toggle').checked=!e;toast('Error: '+x.message);}
  }

  async function mobAddAdmin(){
    var err=_('add-err'),ok=_('add-ok');
    err.className='modal-message';ok.className='modal-message';
    var u=_('add-user').value.trim(),p=_('add-pass').value;
    if(!u||!p){err.textContent='Username & password required';err.classList.add('error');return;}
    try{
      var r=await fetch('/dev/api/admins/add',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:u,password:p})});
      var d=await r.json();
      if(d.error){err.textContent=d.error;err.classList.add('error');}
      else{ok.textContent='Admin "'+u+'" created!';ok.classList.add('success');_('add-user').value='';_('add-pass').value='';toast('Admin created');mobRefresh();}
    }catch(x){err.textContent='Error: '+x.message;err.classList.add('error');}
  }

  mobRefresh();
  setInterval(mobRefresh,30000);
  </script>

</body>
</html>
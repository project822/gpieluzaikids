<!-- ============================================================
     ADMIN MODALS — Add Admin & Reset Password (used on Admins page)
     ============================================================ -->

<div class="modal-overlay" id="add-admin-modal">
  <div class="modal">
    <div class="modal-title">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
      Add New Admin
    </div>
    <div class="modal-error" id="add-admin-error"></div>
    <div class="modal-success" id="add-admin-success"></div>
    <div class="modal-field">
      <label for="new-admin-username">Username</label>
      <input id="new-admin-username" type="text" placeholder="Enter username" autocomplete="off">
    </div>
    <div class="modal-field">
      <label for="new-admin-password">Password</label>
      <input id="new-admin-password" type="password" placeholder="Enter password">
    </div>
    <div class="modal-actions">
      <button class="modal-btn" onclick="closeModal('add-admin-modal')">Cancel</button>
      <button class="modal-btn primary" onclick="submitAddAdmin()">Create Admin</button>
    </div>
  </div>
</div>

<div class="modal-overlay" id="reset-password-modal">
  <div class="modal">
    <div class="modal-title">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
      Reset Password
    </div>
    <div class="modal-error" id="reset-password-error"></div>
    <div class="modal-success" id="reset-password-success"></div>
    <div style="margin-bottom:14px; font-size:13px; color:var(--muted);">
      Resetting password for: <strong id="reset-username-display" style="color:var(--text);"></strong>
    </div>
    <div class="modal-field">
      <label for="reset-new-password">New Password</label>
      <input id="reset-new-password" type="password" placeholder="Enter new password">
    </div>
    <div class="modal-actions">
      <button class="modal-btn" onclick="closeModal('reset-password-modal')">Cancel</button>
      <button class="modal-btn primary" onclick="submitResetPassword()">Update Password</button>
    </div>
  </div>
</div>

<script>
  // ── MODAL HELPERS ──
  function openModal(id) { document.getElementById(id).classList.add('active'); }
  function closeModal(id) {
    const modal = document.getElementById(id);
    modal.classList.remove('active');
    modal.querySelectorAll('input').forEach(inp => inp.value = '');
    modal.querySelector('.modal-error').classList.remove('show');
    modal.querySelector('.modal-error').textContent = '';
    modal.querySelector('.modal-success').classList.remove('show');
    modal.querySelector('.modal-success').textContent = '';
  }
  document.querySelectorAll('.modal-overlay').forEach(overlay => {
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closeModal(overlay.id);
    });
  });

  // ── ADD ADMIN ──
  window.openAddAdminModal = function() { openModal('add-admin-modal'); };

  window.submitAddAdmin = async function() {
    const username = document.getElementById('new-admin-username').value.trim();
    const password = document.getElementById('new-admin-password').value;
    const errorEl = document.getElementById('add-admin-error');
    const successEl = document.getElementById('add-admin-success');
    errorEl.classList.remove('show');
    successEl.classList.remove('show');

    if (!username || !password) {
      errorEl.textContent = 'Username dan password wajib diisi';
      errorEl.classList.add('show');
      return;
    }

    try {
      const res = await fetch('/dev/api/admins/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username, password })
      });
      const data = await res.json();
      if (data.ok) {
        successEl.textContent = 'Admin "' + username + '" berhasil dibuat!';
        successEl.classList.add('show');
        document.getElementById('new-admin-username').value = '';
        document.getElementById('new-admin-password').value = '';
        refreshAdminTable();
      } else {
        errorEl.textContent = data.error || 'Gagal membuat admin';
        errorEl.classList.add('show');
      }
    } catch (e) {
      errorEl.textContent = 'Network error';
      errorEl.classList.add('show');
    }
  };

  // ── RESET PASSWORD ──
  let resetTargetUsername = '';

  window.openResetPasswordModal = function(username) {
    resetTargetUsername = username;
    document.getElementById('reset-username-display').textContent = username;
    openModal('reset-password-modal');
  };

  window.submitResetPassword = async function() {
    const newPassword = document.getElementById('reset-new-password').value;
    const errorEl = document.getElementById('reset-password-error');
    const successEl = document.getElementById('reset-password-success');
    errorEl.classList.remove('show');
    successEl.classList.remove('show');

    if (!newPassword) {
      errorEl.textContent = 'Password baru wajib diisi';
      errorEl.classList.add('show');
      return;
    }

    try {
      const res = await fetch('/dev/api/admins/reset-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username: resetTargetUsername, newPassword })
      });
      const data = await res.json();
      if (data.ok) {
        successEl.textContent = 'Password untuk "' + resetTargetUsername + '" berhasil direset!';
        successEl.classList.add('show');
        document.getElementById('reset-new-password').value = '';
      } else {
        errorEl.textContent = data.error || 'Gagal mereset password';
        errorEl.classList.add('show');
      }
    } catch (e) {
      errorEl.textContent = 'Network error';
      errorEl.classList.add('show');
    }
  };

  // ── DELETE ADMIN ──
  window.deleteAdmin = async function(username) {
    if (!confirm('Yakin ingin menghapus admin "' + username + '"?')) return;
    try {
      const res = await fetch('/dev/api/admins/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username })
      });
      const data = await res.json();
      if (data.ok) {
        refreshAdminTable();
      } else {
        alert(data.error || 'Gagal menghapus admin');
      }
    } catch (e) {
      alert('Network error');
    }
  };

  // ── REFRESH ADMIN TABLE ──
  async function refreshAdminTable() {
    try {
      const res = await fetch('/dev/api/admins/statuses');
      if (!res.ok) return;
      const data = await res.json();
      const admins = data.admins || [];
      const statuses = data.adminStatuses || {};
      const tbody = document.getElementById('admin-table-body');

      if (admins.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" style="padding:16px 20px; color:var(--muted);">No admins found.</td></tr>';
        return;
      }

      let html = '';
      admins.forEach(a => {
        const st = statuses[a.username] || {};
        const online = st.online === true;
        const lastOnline = st.lastOnline ? (() => {
          const d = new Date(st.lastOnline);
          return String(d.getDate()).padStart(2,'0') + '/' + String(d.getMonth()+1).padStart(2,'0') + '/' + d.getFullYear();
        })() : '—';

        html += `<tr data-username="${a.username}">
          <td style="font-weight:700;">${a.username}</td>
          <td>
            <span class="status-pill ${online ? 'online' : 'offline'}">
              <span class="dot"></span>
              ${online ? 'Online' : 'Offline'}
            </span>
          </td>
          <td style="color: var(--muted);">${lastOnline}</td>
          <td>
            <div class="admin-actions-cell">
              <button class="admin-action-btn reset" onclick="openResetPasswordModal('${a.username}')">Reset Password</button>
              <button class="admin-action-btn delete" onclick="deleteAdmin('${a.username}')">Delete</button>
            </div>
          </td>
        </tr>`;
      });
      tbody.innerHTML = html;
    } catch (e) {
      console.warn('[admins] refresh error', e);
    }
  }

  // ── FORCE LOGOUT (single admin) ──
  let forceLogoutTarget = '';

  window.openForceLogoutModal = function(username) {
    forceLogoutTarget = username;
    if (confirm('Yakin ingin memutus sesi admin "' + username + '"? Admin akan di-logout dari semua perangkat.')) {
      submitForceLogout(username);
    }
  };

  window.submitForceLogout = async function(username) {
    try {
      const res = await fetch('/dev/api/admins/force-logout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username })
      });
      const data = await res.json();
      if (data.ok) {
        refreshAdminTable();
      } else {
        alert(data.error || 'Gagal memutus sesi admin');
      }
    } catch (e) {
      alert('Network error');
    }
  };

  // ── FORCE LOGOUT ALL ──
  window.forceLogoutAll = async function() {
    if (!confirm('Yakin ingin memutus sesi SEMUA admin? Semua admin akan di-logout dari semua perangkat dan harus login ulang.')) return;
    try {
      const res = await fetch('/dev/api/admins/force-logout-all', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });
      const data = await res.json();
      if (data.ok) {
        alert('Semua admin telah di-logout. ' + (data.sessionsDeleted || 0) + ' sesi dihapus.');
        refreshAdminTable();
      } else {
        alert(data.error || 'Gagal memutus sesi admin');
      }
    } catch (e) {
      alert('Network error');
    }
  };

  // More frequent refresh: every 5 seconds for real-time status
  setInterval(refreshAdminTable, 5000);
</script>

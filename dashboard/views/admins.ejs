<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Admins — Dev Console</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap"></noscript>
  <%- include('_critical-css') %>
  <link rel="stylesheet" href="/dashboard-assets/css/base.css" media="print" onload="this.media='all'">
  <link rel="stylesheet" href="/dashboard-assets/css/admins.css" media="print" onload="this.media='all'">

  <!-- Vercel Analytics -->
  <script>window.va=window.va||function(){(window.vaq=window.vaq||[]).push(arguments)};</script>
  <script defer src="/_vercel/insights/script.js"></script>
  <script defer src="https://unpkg.com/@vercel/speed-insights/dist/index.js"></script>
</head>
<body>

  <div class="dash-shell">
    <%- include('_sidebar', { active: 'admins' }) %>

    <div class="main">
      <header class="topbar">
        <div class="topbar-heading">
          <button class="hamburger" onclick="toggleSidebar()" aria-label="Toggle sidebar">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
          <h1>Admins</h1>
          <p>Manage admin accounts & access.</p>
        </div>
        <div class="topbar-actions">
          <button class="btn btn-primary" onclick="openAddAdminModal()">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add Admin
          </button>
        </div>
      </header>

      <main class="content">

        <div class="admins-intro">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
          <span>Akun admin di sini digunakan oleh petugas yang menambahkan <strong>event</strong> dan <strong>dokumentasi event</strong> di website. Buat akun baru atau reset password lewat tabel di bawah.</span>
        </div>

        <div class="card">
          <div class="section-header">
            <span>Admin Accounts</span>
            <span class="sub"><%= admins ? admins.length : 0 %> total</span>
          </div>
          <div class="table-scroll" style="overflow-x:auto;">
            <table class="admin-table">
            <thead>
              <tr>
                <th>Username</th>
                <th>Status</th>
                <th>Last Online</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="admin-table-body">
              <% const statuses = adminStatuses || {}; %>
              <% if (admins && admins.length) { %>
                <% admins.forEach(a => {
                     const st = statuses[a.username] || {};
                     const online = st.online === true; %>
                <tr data-username="<%= a.username %>">
                  <td style="font-weight:700;"><%= a.username %></td>
                  <td>
                    <span class="status-pill <%= online ? 'online' : 'offline' %>">
                      <span class="dot"></span>
                      <%= online ? 'Online' : 'Offline' %>
                    </span>
                  </td>
                  <td style="color: var(--muted);">
                    <% if (st.lastOnline) {
                         const d = new Date(st.lastOnline); %>
                      <%= String(d.getDate()).padStart(2,'0') %>/<%= String(d.getMonth()+1).padStart(2,'0') %>/<%= d.getFullYear() %>
                    <% } else { %>—<% } %>
                  </td>
                  <td>
                    <div class="admin-actions-cell">
                      <button class="admin-action-btn force-logout" onclick="openForceLogoutModal('<%= a.username %>')" title="Logout dari semua perangkat">
                        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h10m0 0l-3-3m3 3l-3 3M4 5v14"/></svg>
                        Logout All Devices
                      </button>
                      <button class="admin-action-btn reset" onclick="openResetPasswordModal('<%= a.username %>')">Reset Password</button>
                      <button class="admin-action-btn delete" onclick="deleteAdmin('<%= a.username %>')">Delete</button>
                    </div>
                  </td>
                </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="4" style="padding:16px 20px; color:var(--muted);">No admins found.</td></tr>
              <% } %>
            </tbody>
          </table>
          </div>
        </div>

      </main>
    </div>
  </div>

  <%- include('_admin-modals') %>

</body>
</html>

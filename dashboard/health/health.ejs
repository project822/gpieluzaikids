<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Health Check — Dev Console</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <%- include('_critical-css') %>
  <link rel="stylesheet" href="/dashboard-assets/shared/base.css">
  <link rel="stylesheet" href="/dashboard-assets/health/health.css">

  <script>window.va=window.va||function(){(window.vaq=window.vaq||[]).push(arguments)};</script>
  <script defer src="/_vercel/insights/script.js"></script>
</head>
<body>

  <div class="dash-shell">
    <%- include('_sidebar', { active: 'health' }) %>

    <div class="main">
      <header class="topbar">
        <div class="topbar-heading">
          <button class="hamburger" onclick="toggleSidebar()" aria-label="Toggle sidebar">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
          <h1>Health Check</h1>
          <p>Status real-time database, website, dan performa sistem.</p>
        </div>
        <div class="topbar-actions">
          <div class="online-badge" id="hc-last-checked">
            <span class="online-dot"></span>
            <span>Checking...</span>
          </div>
          <button class="btn" onclick="runHealthCheck()">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
            Refresh
          </button>
        </div>
      </header>

      <main class="content">

        <!-- Status Overview Cards -->
        <div class="hc-status-grid">
          <div class="hc-status-card" id="hc-card-website">
            <div class="hc-status-icon" id="hc-icon-website">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"/></svg>
            </div>
            <div class="hc-status-info">
              <div class="hc-status-name">Website</div>
              <div class="hc-status-val" id="hc-val-website">Checking...</div>
            </div>
            <div class="hc-status-badge" id="hc-badge-website">—</div>
          </div>

          <div class="hc-status-card" id="hc-card-db">
            <div class="hc-status-icon" id="hc-icon-db">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
            </div>
            <div class="hc-status-info">
              <div class="hc-status-name">Database (MongoDB)</div>
              <div class="hc-status-val" id="hc-val-db">Checking...</div>
            </div>
            <div class="hc-status-badge" id="hc-badge-db">—</div>
          </div>

          <div class="hc-status-card" id="hc-card-latency">
            <div class="hc-status-icon" id="hc-icon-latency">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <div class="hc-status-info">
              <div class="hc-status-name">Avg Latency</div>
              <div class="hc-status-val" id="hc-val-latency">—</div>
            </div>
            <div class="hc-status-badge" id="hc-badge-latency">—</div>
          </div>

          <div class="hc-status-card" id="hc-card-uptime">
            <div class="hc-status-icon" id="hc-icon-uptime">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            </div>
            <div class="hc-status-info">
              <div class="hc-status-name">Process Uptime</div>
              <div class="hc-status-val" id="hc-val-uptime">—</div>
            </div>
            <div class="hc-status-badge" id="hc-badge-uptime">—</div>
          </div>
        </div>

        <div class="card">
            <div class="section-header">
              <span>System Info</span>
              <span class="sub">Server / Node.js</span>
            </div>
            <div class="hc-sysinfo" id="hc-sysinfo">
              <div class="hc-loading" id="hc-sys-loading">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="spin-icon"><circle cx="12" cy="12" r="10" stroke-dasharray="31.4 31.4" stroke-linecap="round"/></svg>
                Loading...
              </div>
              <div id="hc-sys-data" style="display:none;">
                <div class="hc-sysrow">
                  <span class="hc-sys-label">Platform</span>
                  <span class="hc-sys-val" id="sys-platform">—</span>
                </div>
                <div class="hc-sysrow">
                  <span class="hc-sys-label">Node Version</span>
                  <span class="hc-sys-val" id="sys-node">—</span>
                </div>
                <div class="hc-sysrow">
                  <span class="hc-sys-label">Memory (heap used)</span>
                  <span class="hc-sys-val" id="sys-mem">—</span>
                </div>
                <div class="hc-sysrow">
                  <span class="hc-sys-label">Memory (heap total)</span>
                  <span class="hc-sys-val" id="sys-mem-total">—</span>
                </div>
                <div class="hc-sysrow">
                  <span class="hc-sys-label">Total Requests</span>
                  <span class="hc-sys-val" id="sys-requests">—</span>
                </div>
                <div class="hc-sysrow">
                  <span class="hc-sys-label">Avg Latency</span>
                  <span class="hc-sys-val" id="sys-latency">—</span>
                </div>
                <div class="hc-sysrow">
                  <span class="hc-sys-label">Maintenance Mode</span>
                  <span class="hc-sys-val" id="sys-maintenance">—</span>
                </div>
                <div class="hc-sysrow">
                  <span class="hc-sys-label">DB Ping</span>
                  <span class="hc-sys-val" id="sys-db-ping">—</span>
                </div>
              </div>
            </div>
          </div>

        <!-- Historical Health Timeline -->
        <div class="card" style="margin-top:16px;">
          <div class="section-header">
            <span>Request Latency History</span>
            <span class="sub" id="hc-history-sub">Last 20 checks</span>
          </div>
          <div class="hc-timeline" id="hc-timeline">
            <div class="hc-loading">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="spin-icon"><circle cx="12" cy="12" r="10" stroke-dasharray="31.4 31.4" stroke-linecap="round"/></svg>
              Collecting data...
            </div>
          </div>
        </div>

        <!-- ── BACKUP STATUS ── -->
        <div class="card" style="margin-top:16px;">
          <div class="section-header">
            <span>Database Backup</span>
            <span class="sub">MongoDB snapshots</span>
          </div>
          <div id="hc-backup-body">
            <div class="hc-loading" id="hc-bu-loading">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="spin-icon"><circle cx="12" cy="12" r="10" stroke-dasharray="31.4 31.4" stroke-linecap="round"/></svg>
              Loading backup info...
            </div>
            <div id="hc-bu-data" style="display:none;">
              <div class="hc-bu-header">
                <div class="hc-bu-status" id="hc-bu-status">
                  <span class="hc-bu-dot ok"></span>
                  <span id="hc-bu-status-text">No backup yet</span>
                </div>
                <button class="btn btn-primary" onclick="triggerBackup()" id="hc-bu-btn" style="font-size:11px;padding:5px 12px;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                  Backup Now
                </button>
              </div>
              <div class="hc-bu-info" id="hc-bu-info">
                <div class="hc-sysrow">
                  <span class="hc-sys-label">Last Backup</span>
                  <span class="hc-sys-val" id="hc-bu-last">—</span>
                </div>
                <div class="hc-sysrow">
                  <span class="hc-sys-label">Events Saved</span>
                  <span class="hc-sys-val" id="hc-bu-events">—</span>
                </div>
                <div class="hc-sysrow">
                  <span class="hc-sys-label">Total Backups</span>
                  <span class="hc-sys-val" id="hc-bu-total">—</span>
                </div>
                <div class="hc-sysrow">
                  <span class="hc-sys-label">Triggered By</span>
                  <span class="hc-sys-val" id="hc-bu-triggered">—</span>
                </div>
              </div>
              <div id="hc-bu-feedback" style="display:none;padding:8px 14px;border-radius:6px;font-size:12px;margin-top:8px;"></div>
            </div>
          </div>
        </div>

      </main>
    </div>
  </div>

  <script>
  const latencyHistory = [];
  const MAX_HISTORY = 20;

  function fmtUptime(seconds) {
    if (seconds < 60) return seconds + 's';
    if (seconds < 3600) return Math.floor(seconds / 60) + 'm ' + (seconds % 60) + 's';
    const h = Math.floor(seconds / 3600);
    const m = Math.floor((seconds % 3600) / 60);
    return h + 'h ' + m + 'm';
  }

  function setCard(id, status, label, value) {
    // status: 'ok' | 'warn' | 'error' | 'loading'
    const card = document.getElementById('hc-card-' + id);
    const icon = document.getElementById('hc-icon-' + id);
    const val  = document.getElementById('hc-val-' + id);
    const badge = document.getElementById('hc-badge-' + id);
    if (!card) return;
    card.className = 'hc-status-card ' + status;
    if (icon) icon.className = 'hc-status-icon ' + status;
    if (val)  val.textContent = value;
    if (badge) {
      badge.textContent = label;
      badge.className = 'hc-status-badge ' + status;
    }
  }

  function renderTimeline() {
    const el = document.getElementById('hc-timeline');
    if (!latencyHistory.length) {
      el.innerHTML = '<div class="hc-loading">Belum ada data latency. Auto-refresh dalam 30 detik.</div>';
      return;
    }
    const max = Math.max(...latencyHistory.map(h => h.v), 1);
    let html = '<div class="hc-tl-bars">';
    latencyHistory.forEach(h => {
      const pct = Math.round((h.v / max) * 100);
      const color = h.v <= 200 ? 'var(--green)' : h.v <= 800 ? 'var(--orange)' : 'var(--red)';
      html += `<div class="hc-tl-bar-wrap" title="${h.t}: ${h.v}ms">
        <div class="hc-tl-bar" style="height:${Math.max(pct,4)}%;background:${color};"></div>
        <div class="hc-tl-label">${h.v}ms</div>
      </div>`;
    });
    html += '</div>';
    el.innerHTML = html;
    document.getElementById('hc-history-sub').textContent = 'Last ' + latencyHistory.length + ' checks';
  }

  async function runHealthCheck() {
    try {
      // Ping health API
      const t0 = performance.now();
      const res = await fetch('/api/dev/health');
      const ping = Math.round(performance.now() - t0);
      const data = await res.json();

      // Website
      if (data.website === 'ok') {
        setCard('website', 'ok', 'Online', ping + 'ms response');
      } else {
        setCard('website', 'error', 'Degraded', 'Error detected');
      }

      // DB
      if (data.db === 'ok') {
        setCard('db', 'ok', 'Connected', data.dbPingMs + 'ms ping');
      } else {
        setCard('db', 'error', 'Disconnected', data.dbError || 'Connection failed');
      }

      // Latency
      const lat = data.avgLatencyMs || 0;
      const latStatus = lat === 0 ? 'loading' : lat < 200 ? 'ok' : lat < 800 ? 'warn' : 'error';
      const latLabel = lat === 0 ? '—' : lat < 200 ? 'Fast' : lat < 800 ? 'Moderate' : 'Slow';
      setCard('latency', latStatus, latLabel, lat + 'ms avg');

      // Uptime
      const up = data.uptimeSeconds || 0;
      setCard('uptime', 'ok', 'Running', fmtUptime(up));

      // System info
      document.getElementById('hc-sys-loading').style.display = 'none';
      document.getElementById('hc-sys-data').style.display = 'block';
      document.getElementById('sys-platform').textContent   = data.platform || '—';
      document.getElementById('sys-node').textContent       = data.nodeVersion || '—';
      document.getElementById('sys-mem').textContent        = data.memHeapUsedMB ? data.memHeapUsedMB + ' MB' : '—';
      document.getElementById('sys-mem-total').textContent  = data.memHeapTotalMB ? data.memHeapTotalMB + ' MB' : '—';
      document.getElementById('sys-requests').textContent   = data.totalRequests != null ? data.totalRequests : '—';
      document.getElementById('sys-latency').textContent    = lat + 'ms';
      document.getElementById('sys-maintenance').textContent = data.maintenanceMode ? '🔴 ON' : '🟢 OFF';
      document.getElementById('sys-db-ping').textContent    = data.db === 'ok' ? (data.dbPingMs + 'ms') : '❌ Failed';

      // Track latency history
      const now = new Date();
      const label = String(now.getHours()).padStart(2,'0') + ':' +
                    String(now.getMinutes()).padStart(2,'0') + ':' +
                    String(now.getSeconds()).padStart(2,'0');
      latencyHistory.push({ t: label, v: ping });
      if (latencyHistory.length > MAX_HISTORY) latencyHistory.shift();
      renderTimeline();

      // Last checked
      document.getElementById('hc-last-checked').innerHTML =
        '<span class="online-dot"></span><span>Updated ' + label + '</span>';

    } catch (e) {
      setCard('website', 'error', 'Error', e.message);
      console.error('[health] check failed', e);
    }
  }

  // ── BACKUP STATUS ──
  async function loadBackupStatus() {
    try {
      const res = await fetch('/api/dev/backup/status');
      const data = await res.json();

      document.getElementById('hc-bu-loading').style.display = 'none';
      document.getElementById('hc-bu-data').style.display = 'block';

      if (data.hasBackup && data.latestBackup) {
        const lb = data.latestBackup;
        document.getElementById('hc-bu-status-text').textContent = 'Backup available';
        document.getElementById('hc-bu-last').textContent = new Date(lb.createdAt).toLocaleString('id-ID');
        document.getElementById('hc-bu-events').textContent = (lb.summary && lb.summary.events) || '—';
        document.getElementById('hc-bu-total').textContent = data.totalBackups || 0;
        document.getElementById('hc-bu-triggered').textContent = lb.triggeredBy || '—';
      } else {
        document.getElementById('hc-bu-status-text').textContent = 'Belum ada backup';
        document.getElementById('hc-bu-last').textContent = '—';
        document.getElementById('hc-bu-total').textContent = 0;
      }
    } catch (_) {
      document.getElementById('hc-bu-loading').textContent = 'Gagal memuat data backup.';
    }
  }

  window.triggerBackup = async function() {
    const btn = document.getElementById('hc-bu-btn');
    const feedback = document.getElementById('hc-bu-feedback');
    btn.disabled = true;
    btn.textContent = 'Backing up...';
    try {
      const res = await fetch('/api/dev/backup/create', { method: 'POST' });
      const data = await res.json();
      if (data.ok) {
        feedback.style.display = 'block';
        feedback.style.background = 'rgba(16,185,129,0.10)';
        feedback.style.color = '#10B981';
        feedback.textContent = '✓ Backup berhasil! (' + new Date().toLocaleString('id-ID') + ')';
        loadBackupStatus();
      } else {
        throw new Error(data.error || 'Backup failed');
      }
    } catch (e) {
      feedback.style.display = 'block';
      feedback.style.background = 'rgba(239,68,68,0.10)';
      feedback.style.color = '#EF4444';
      feedback.textContent = '✗ Gagal: ' + e.message;
    } finally {
      btn.disabled = false;
      btn.textContent = 'Backup Now';
      setTimeout(() => { feedback.style.display = 'none'; }, 5000);
    }
  };

  loadBackupStatus();

  // Init
  runHealthCheck();
  setInterval(runHealthCheck, 30000);
  </script>

</body>
</html>

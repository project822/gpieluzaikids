<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover">
  <title>Dev Console · Mobile</title>
  <link rel="stylesheet" href="/dashboard-assets/dashboard-mobile/dashboard-mobile.css">
</head>
<body>

  <%- include('shared/_header') %>

  <!-- CONTENT -->
  <main class="app-content" id="app-content">

    <section class="app-tab active" id="t-home">
      <%- include('home/home') %>
    </section>

    <section class="app-tab" id="t-overview">
      <%- include('overview/overview') %>
    </section>

    <section class="app-tab" id="t-activity">
      <%- include('activity/activity') %>
    </section>

    <section class="app-tab" id="t-system">
      <%- include('system/system') %>
    </section>

    <section class="app-tab" id="t-security">
      <%- include('security/security') %>
    </section>

    <section class="app-tab" id="t-monitoring">
      <%- include('monitor/monitor') %>
    </section>

    <section class="app-tab" id="t-account">
      <%- include('accounts/accounts') %>
    </section>

  </main>

  <%- include('shared/_tabbar', { active: 'home' }) %>
  <%- include('shared/_modal') %>
  <%- include('shared/_toast') %>
  <%- include('shared/_scripts') %>

</body>
</html>

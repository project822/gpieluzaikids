<!-- ═══ RESET PASSWORD MODAL ═══ -->
<div class="modal-overlay" id="rp-modal">
  <div class="modal-sheet">
    <div class="modal-sheet-header">
      <h3>Reset Password</h3>
      <button class="modal-sheet-close" onclick="mobCloseModal('rp-modal')">&times;</button>
    </div>
    <div class="modal-sheet-body">
      <div class="modal-message" id="rp-err"></div>
      <div class="modal-message" id="rp-ok"></div>
      <div class="form-field">
        <label>Username</label>
        <input type="text" id="rp-user" readonly style="opacity:0.6;">
      </div>
      <div class="form-field">
        <label>Password Baru</label>
        <input type="password" id="rp-pass" placeholder="Masukkan password baru">
      </div>
      <button class="btn-primary" onclick="mobResetPass()">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        Update Password
      </button>
    </div>
  </div>
</div>

<!-- ═══ ADD ADMIN MODAL ═══ -->
<div class="modal-overlay" id="aa-modal">
  <div class="modal-sheet">
    <div class="modal-sheet-header">
      <h3>Add Admin</h3>
      <button class="modal-sheet-close" onclick="mobCloseModal('aa-modal')">&times;</button>
    </div>
    <div class="modal-sheet-body">
      <div class="modal-message" id="aa-err"></div>
      <div class="modal-message success" id="aa-ok"></div>
      <div class="form-field">
        <label>Username</label>
        <input type="text" id="aa-username" placeholder="Masukkan username" autocomplete="off">
      </div>
      <div class="form-field">
        <label>Password</label>
        <input type="password" id="aa-password" placeholder="Masukkan password">
      </div>
      <button class="btn-primary" onclick="mobAddAdmin()">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Tambah Admin
      </button>
    </div>
  </div>
</div>

<!-- ═══ DELETE ADMIN CONFIRM MODAL ═══ -->
<div class="modal-overlay" id="da-modal">
  <div class="modal-sheet">
    <div class="modal-sheet-header">
      <h3>Delete Admin</h3>
      <button class="modal-sheet-close" onclick="mobCloseModal('da-modal')">&times;</button>
    </div>
    <div class="modal-sheet-body">
      <div class="modal-message" id="da-err"></div>
      <div class="modal-message success" id="da-ok"></div>
      <p style="color:var(--muted);font-size:13px;margin-bottom:12px;">This will permanently delete <strong id="da-username-display">—</strong>. They will lose all access immediately.</p>
      <button class="btn-primary" onclick="mobDeleteAdmin()" style="background:#DC2626;">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        Delete Admin
      </button>
    </div>
  </div>
</div>

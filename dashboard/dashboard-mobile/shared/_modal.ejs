<!-- ═══ RESET PASSWORD MODAL ═══ -->
<div class="modal-overlay" id="rp-modal">
  <div class="modal-sheet">
    <div class="modal-sheet-header">
      <h3>Reset Password</h3>
      <button class="modal-sheet-close" onclick="mobCloseModal('rp-modal')">&times;</button>
    </div>
    <div class="modal-sheet-body">
      <div class="modal-message" id="rp-err"></div>
      <div class="modal-message" id="rp-ok"></div>
      <div class="form-field">
        <label>Username</label>
        <input type="text" id="rp-user" readonly style="opacity:0.6;">
      </div>
      <div class="form-field">
        <label>Password Baru</label>
        <input type="password" id="rp-pass" placeholder="Masukkan password baru">
      </div>
      <button class="btn-primary" onclick="mobResetPass()">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        Update Password
      </button>
    </div>
  </div>
</div>

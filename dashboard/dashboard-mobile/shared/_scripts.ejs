<!-- ═══ JAVASCRIPT ═══ -->
<script>
var _ = document.getElementById.bind(document);

function fmtU(s) {
  if (s == null) return '---';
  if (s < 60) return Math.round(s) + 's';
  if (s < 3600) return Math.floor(s/60) + 'm ' + Math.round(s%60) + 's';
  return Math.floor(s/3600) + 'h ' + Math.floor((s%3600)/60) + 'm';
}

function toast(m) {
  var t=_('toast'); t.textContent=m; t.classList.add('show');
  clearTimeout(t._h); t._h=setTimeout(function(){t.classList.remove('show')},2500);
}

function mobTab(n) {
  document.querySelectorAll('.app-tab').forEach(function(t){t.classList.remove('active')});
  document.querySelectorAll('.app-tabbar-item').forEach(function(b){b.classList.remove('active')});
  _('t-'+n).classList.add('active');
  document.querySelector('.app-tabbar-item[data-tab="'+n+'"]').classList.add('active');
}

function mobCloseModal(id) {
  _(id).classList.remove('active');
}
document.addEventListener('click',function(e){
  if(e.target.classList.contains('modal-overlay')){e.target.classList.remove('active');}
});

/* ════════ SESSION CHECK / REDIRECT ════════ */
function mobRedirectLogin() {
  window.location.href = '/dev/login';
}

/* ════════ REFRESH ════════ */
async function mobRefresh() {
  var ri=_('ri'); if(ri)ri.classList.add('app-btn-spin');
  setTimeout(function(){if(ri)ri.classList.remove('app-btn-spin')},500);
  try {
    var healthRes = await fetch('/api/dev/health');
    // Jika 401 (session expired), redirect ke login
    if (healthRes.status === 401) {
      toast('Sesi telah berakhir. Mengarahkan ke login...');
      setTimeout(mobRedirectLogin, 1500);
      return;
    }
    var h=await healthRes.json();

    // — HOME: 4-item status banner —
    function setBannerDot(id, status) {
      var el = _('hm-dot-'+id);
      if(el) el.className = 'hm-banner-dot ' + status;
    }
    function setBannerVal(id, val) {
      var el = _('hm-val-'+id);
      if(el) el.textContent = val;
    }
    setBannerDot('website', h.website==='ok'?'ok':'error');
    setBannerVal('website', h.website==='ok'?'Online':'Error');
    setBannerDot('db', h.db==='ok'?'ok':'error');
    setBannerVal('db', h.db==='ok'?h.dbPingMs+'ms':(h.dbError||'Disconnected'));

    // — HOME: Stats —
    var s=await(await fetch('/api/dev/stats')).json(),pv=s.pvStats||{};
    _('hm-stat-visitors').textContent=pv.visitors||0;
    _('hm-stat-pageviews').textContent=pv.pageviews||0;
    _('hm-stat-latency').innerHTML=(s.metrics?(s.metrics.avgLatencyMs||0):0)+'<span class="unit">ms</span>';
    _('hm-stat-requests').textContent=(h.totalRequests||0);

    // — HOME: Server Info —
    _('hm-server-uptime').textContent=fmtU(h.uptimeSeconds||0);
    _('hm-server-mem').textContent=(h.memHeapUsedMB||0)+' MB';
    _('hm-server-node').textContent=h.nodeVersion||'---';
    _('hm-server-plat').textContent=h.platform||'---';
    _('hm-server-dbping').textContent=(h.dbPingMs||0)+'ms';

    // — HOME: Online Admins —
    var a=await(await fetch('/dev/api/admins/statuses')).json();
    var sts=a.adminStatuses||{},adms=a.admins||[];
    var ol=adms.filter(function(x){return sts[x.username]&&sts[x.username].online===true});
    var ac=_('hm-admin-card'), al=_('hm-admin-list'), aload=_('hm-admin-loading');
    if(aload) aload.style.display='none';
    if(al){
      al.style.display='block';
      al.innerHTML=!ol.length?'<div class="app-card-empty">Tidak ada admin online saat ini.</div>':
        ol.map(function(x){
          var lastOn=sts[x.username].lastOnline?new Date(sts[x.username].lastOnline).toLocaleString('id-ID'):'---';
          return '<div class="account-item">'+
            '<div class="account-item-left">'+
              '<div class="account-item-avatar">'+x.username.charAt(0).toUpperCase()+'</div>'+
              '<div class="account-item-info">'+
                '<span class="account-item-name">'+x.username+'</span>'+
                '<span class="account-item-status">'+
                  '<span style="width:6px;height:6px;border-radius:50%;background:#22c55e;display:inline-block;"></span> Online'+
                '</span>'+
                '<span style="font-size:10px;color:#64748b;margin-top:1px;">Last: '+lastOn+'</span>'+
              '</div>'+
            '</div>'+
          '</div>';
        }).join('');
    }

    // — Content Stats —
    try {
      var cs=await(await fetch('/api/dev/content-stats')).json();
      _('hm-cs-events').textContent=cs.events||0;
      _('hm-cs-docs').textContent=cs.documentation||0;
      _('hm-cs-admins').textContent=cs.admins||0;
      _('hm-cs-backups').textContent=cs.backups||0;
    }catch(e){}

    // — Maintenance status on banner —
    try {
      var mtSt=await(await fetch('/api/dev/maintenance/status')).json();
      setBannerDot('mt', mtSt.enabled?'warn':'ok');
      setBannerVal('mt', mtSt.enabled?'ACTIVE':'Inactive');
    }catch(e){ setBannerDot('mt','warn'); setBannerVal('mt','Error'); }

    // — Content Stats (for activity tab) —
    var csData = null;
    try {
      csData=await(await fetch('/api/dev/content-stats')).json();
      _('ac-stat-events').textContent=csData.events||0;
      _('ac-stat-docs').textContent=csData.documentation||0;
      _('ac-stat-admins').textContent=csData.admins||0;
    }catch(e){}

    // — ACTIVITY TAB —
    window._mobLogs = [];
    try {
      var acRes=await(await fetch('/api/dev/activity-logs?limit=50')).json();
      window._mobLogs=acRes.logs||[];
      _('ac-total-logs').textContent=window._mobLogs.length;
      _('ac-loading').style.display='none';
      mobRenderLogs('all');
    }catch(e){ _('ac-loading').style.display='none'; _('ac-empty').style.display='block'; }

    // — ACCOUNT TAB: admin list —
    var acLoading=document.querySelector('#ac-admin-list .app-card-loading');
    if(acLoading) acLoading.style.display='none';
    _('ac-admin-list-content').style.display='block';
    _('ac-admin-list-content').innerHTML=!adms.length?'<div class="app-card-empty">No admins</div>':
      adms.map(function(x){
        var s=sts[x.username]||{},io=s.online===true,inl=x.username.charAt(0).toUpperCase();
        var lastOn=s.lastOnline?new Date(s.lastOnline).toLocaleString('id-ID'):'---';
        return '<div class="account-item">'+
          '<div class="account-item-left">'+
            '<div class="account-item-avatar">'+inl+'</div>'+
            '<div class="account-item-info">'+
              '<span class="account-item-name">'+x.username+'</span>'+
              '<span class="account-item-status">'+
                '<span style="width:6px;height:6px;border-radius:50%;background:'+(io?'#22c55e':'#64748b')+';display:inline-block;"></span> '+
                (io?'Online':'Offline')+
              '</span>'+
              '<span style="font-size:10px;color:#64748b;margin-top:1px;">Last: '+lastOn+'</span>'+
            '</div>'+
          '</div>'+
          '<div class="account-item-actions">'+
            '<button class="account-action-btn" onclick="mobShowReset(\''+x.username+'\')" title="Reset Password">'+
              '<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>'+
            '</button>'+
            '<button class="account-action-btn danger" onclick="mobForceLogout(\''+x.username+'\')" title="Logout Device">'+
              '<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>'+
            '</button>'+
            '<button class="account-action-btn danger" onclick="mobShowDelete(\''+x.username+'\')" title="Delete Admin">'+
              '<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>'+
            '</button>'+
          '</div>'+
        '</div>';
      }).join('');

    // — MAINTENANCE (System tab) —
    var mt=await(await fetch('/api/dev/maintenance/status')).json();
    _('sys-mt-toggle').checked=mt.enabled===true;
    _('sys-mt-message').value=mt.message||'Website sedang dalam perbaikan. Silakan kembali lagi nanti.';
    var mtIcon=_('sys-mt-icon');
    if(mtIcon){
      mtIcon.className='mt-hero-icon '+(mt.enabled?'on':'off');
    }
    var mtSub=_('sys-mt-sub');
    if(mtSub){
      mtSub.textContent=mt.enabled?'Pengguna sedang melihat halaman maintenance.':'Website berjalan normal. Aktifkan untuk menampilkan halaman perawatan.';
    }
    updatePreview();

    // — SECURITY TAB — load stats (fire-and-forget, don't block refresh)
    mobLoadSecurity(false).catch(function(e){console.warn('[security]',e);});

  }catch(e){console.warn('[mobile-v2]',e);}
}

/* ════════ MAINTENANCE — TOGGLE ════════ */
async function mobToggleMt(e){
  try{
    var msg = _('sys-mt-message').value.trim();
    var r=await fetch('/api/dev/maintenance',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({enabled:e, message:msg || undefined})});
    if(r.status===401){_('sys-mt-toggle').checked=!e;toast('Sesi habis, redirect...');setTimeout(mobRedirectLogin,1500);return;}
    var d=await r.json();if(!d.ok)throw new Error(d.error);
    toast(e?'Maintenance ON':'Maintenance OFF');
    var icon=_('sys-mt-icon');
    if(icon) icon.className='mt-hero-icon '+(e?'on':'off');
    var sub=_('sys-mt-sub');
    if(sub){
      sub.textContent=e?'Pengguna sedang melihat halaman maintenance.':'Website berjalan normal. Aktifkan untuk menampilkan halaman perawatan.';
    }
  }catch(x){_('sys-mt-toggle').checked=!e;toast('Error: '+x.message);}
}

/* ════════ MAINTENANCE — SAVE MESSAGE ════════ */
async function mobSaveMtMsg() {
  var msg = _('sys-mt-message').value.trim();
  if (!msg) { showMtFeedback('Pesan tidak boleh kosong.', 'error'); return; }
  var enabled = _('sys-mt-toggle').checked;
  try {
    var r = await fetch('/api/dev/maintenance',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({enabled:enabled, message:msg})});
    if(r.status===401){showMtFeedback('Sesi habis, redirect...','error');setTimeout(mobRedirectLogin,1500);return;}
    var d = await r.json();
    if (!d.ok) throw new Error(d.error || 'Gagal');
    showMtFeedback('✓ Pesan berhasil disimpan', 'success');
  } catch (x) {
    showMtFeedback('Gagal menyimpan: '+x.message, 'error');
  }
}

function showMtFeedback(msg, type) {
  var el = _('sys-mt-feedback');
  el.textContent = msg;
  el.className = 'mt-feedback ' + type;
  el.style.display = 'block';
  setTimeout(function(){ el.style.display = 'none'; }, 3000);
}

/* ════════ MAINTENANCE — LIVE PREVIEW ════════ */
function updatePreview() {
  var msgEl = _('sys-mt-message');
  var previewEl = _('sys-mt-preview-msg');
  if (msgEl && previewEl) {
    previewEl.textContent = msgEl.value || 'Website sedang dalam perbaikan. Silakan kembali lagi nanti.';
  }
}

/* ════════ SECURITY — LOAD DATA ════════ */
async function mobLoadSecurity(showToast) {
  try {
    var statsRes = await fetch('/api/dev/security/stats');
    var stats = await statsRes.json();

    _('sec-events24h').textContent = stats.events24h || 0;
    _('sec-rate-limited').textContent = stats.rateLimited || 0;
    _('sec-bot').textContent = stats.botDetected || 0;
    _('sec-blocked-count').textContent = stats.blockedIpCount || 0;
    var totEl = _('sec-blocked-total');
    if (totEl) totEl.textContent = (stats.blockedIpCount || 0) + ' entries';

    // Top IPs
    var top = stats.topIps || [];
    var topEmpty = _('sec-top-empty');
    var topData = _('sec-top-data');
    if (top.length) {
      if (topEmpty) topEmpty.style.display = 'none';
      if (topData) topData.style.display = 'block';
      var topBody = _('sec-top-body');
      if (topBody) {
        topBody.innerHTML = top.map(function(ip){
          var cnt = ip.count || 0;
          var cls = cnt >= 10 ? 'high' : cnt >= 5 ? 'mid' : 'low';
          var safeIp = ip.ip.replace(/'/g, "\\'");
          return '<tr>'+
            '<td class="sec-ip-cell">'+ip.ip+'</td>'+
            '<td><span class="sec-count-badge '+cls+'">'+cnt+'</span></td>'+
            '<td><button class="sec-action-btn" onclick="mobBlockIpDirect(\''+safeIp+'\')">Block</button></td></tr>';
        }).join('');
      }
    } else {
      if (topEmpty) { topEmpty.style.display = 'block'; topEmpty.textContent = 'Belum ada data keamanan.'; }
      if (topData) topData.style.display = 'none';
    }

    // Blocked IPs list
    var blocked = stats.blockedIps || [];
    var blockedList = _('sec-blocked-list');
    var blockedEmpty = _('sec-blocked-empty');
    if (blockedList) {
      if (blocked.length) {
        if (blockedEmpty) blockedEmpty.style.display = 'none';
        blocked.forEach(function(ip){
          var safeId = ip.replace(/\./g, '-');
          var row = document.getElementById('sec-ip-'+safeId);
          if (!row) {
            var div = document.createElement('div');
            div.className = 'sec-ip-row';
            div.id = 'sec-ip-'+safeId;
            div.innerHTML = '<span class="sec-ip-val">'+ip+'</span><button class="sec-action-btn" onclick="mobUnblockIp(\''+ip+'\')">Unblock</button>';
            blockedList.appendChild(div);
          }
        });
      }
    }

    // Security logs
    var logs = stats.logs || [];
    var logsEmpty = _('sec-logs-empty');
    var logsData = _('sec-logs-data');
    var logsCount = _('sec-logs-count');
    if (logsCount) logsCount.textContent = logs.length + ' entries';

    if (logs.length) {
      if (logsEmpty) logsEmpty.style.display = 'none';
      if (logsData) logsData.style.display = 'block';
      var logsBody = _('sec-logs-body');
      if (logsBody) {
        logsBody.innerHTML = logs.map(function(l){
          var ts = l.timestamp ? new Date(l.timestamp).toLocaleString('id-ID') : '—';
          var type = l.type || 'unknown';
          var typeCls = type;
          var ip = l.ip || '—';
          var path = l.path || '—';
          var detail = l.detail || '';
          return '<tr>'+
            '<td class="sec-ts-cell">'+ts+'</td>'+
            '<td><span class="sec-type-badge '+typeCls+'">'+type+'</span></td>'+
            '<td class="sec-ip-cell">'+ip+'</td>'+
            '<td class="sec-path-cell">'+path+'</td>'+
            '<td class="sec-detail-cell">'+detail+'</td></tr>';
        }).join('');
      }
    } else {
      if (logsEmpty) logsEmpty.style.display = 'block';
      if (logsData) logsData.style.display = 'none';
    }

    if (showToast) toast('Security data refreshed');
  } catch(e) {
    console.warn('[mobLoadSecurity]', e);
    if (showToast) toast('Gagal memuat data keamanan');
  }
}

/* ════════ SECURITY — BLOCK IP ════════ */
async function mobBlockIp() {
  var ip = _('sec-ip-input').value.trim();
  if (!ip) { showSecFeedback('Masukkan IP address.', 'error'); return; }
  await mobBlockIpDirect(ip);
}

async function mobBlockIpDirect(ip) {
  try {
    var r = await fetch('/api/dev/security/block-ip', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ip:ip})});
    if(r.status===401){toast('Sesi habis, redirect...');setTimeout(mobRedirectLogin,1500);return;}
    var d = await r.json();
    if (!d.ok) throw new Error(d.error || 'Gagal');
    _('sec-ip-input').value = '';
    showSecFeedback('✓ IP '+ip+' berhasil diblokir', 'success');
    var blockedList = _('sec-blocked-list');
    var blockedEmpty = _('sec-blocked-empty');
    if (blockedEmpty) blockedEmpty.style.display = 'none';
    var safeId = ip.replace(/\./g, '-');
    if (!document.getElementById('sec-ip-'+safeId)) {
      var div = document.createElement('div');
      div.className = 'sec-ip-row';
      div.id = 'sec-ip-'+safeId;
      div.innerHTML = '<span class="sec-ip-val">'+ip+'</span><button class="sec-action-btn" onclick="mobUnblockIp(\''+ip+'\')">Unblock</button>';
      blockedList.appendChild(div);
    }
  } catch(x) {
    showSecFeedback('Gagal memblokir: '+x.message, 'error');
  }
}

async function mobUnblockIp(ip) {
  try {
    var r = await fetch('/api/dev/security/unblock-ip', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ip:ip})});
    if(r.status===401){toast('Sesi habis, redirect...');setTimeout(mobRedirectLogin,1500);return;}
    var d = await r.json();
    if (!d.ok) throw new Error(d.error || 'Gagal');
    toast('✓ IP '+ip+' dihapus');
    var safeId = ip.replace(/\./g, '-');
    var row = document.getElementById('sec-ip-'+safeId);
    if (row) row.remove();
    var blockedRows = document.querySelectorAll('#sec-blocked-list > .sec-ip-row');
    if (!blockedRows.length) {
      var blockedEmpty = _('sec-blocked-empty');
      if (blockedEmpty) blockedEmpty.style.display = 'block';
    }
  } catch(x) {
    toast('Gagal: '+x.message);
  }
}

function showSecFeedback(msg, type) {
  var el = _('sec-block-feedback');
  el.textContent = msg;
  el.className = 'sec-feedback ' + type;
  el.style.display = 'block';
  setTimeout(function(){ el.style.display = 'none'; }, 3000);
}

/* ════════ ACCOUNT — RESET PASSWORD ════════ */
function mobShowReset(user) {
  _('rp-user').value = user;
  _('rp-pass').value = '';
  _('rp-err').style.display = 'none';
  _('rp-err').textContent = '';
  _('rp-ok').style.display = 'none';
  _('rp-ok').textContent = '';
  _('rp-modal').classList.add('active');
}

async function mobResetPass() {
  var user = _('rp-user').value;
  var pass = _('rp-pass').value.trim();
  if (!pass) { _('rp-err').textContent = 'Password tidak boleh kosong.'; _('rp-err').style.display = 'block'; return; }
  try {
    var r = await fetch('/api/dev/admins/reset-password', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({username:user, newPassword:pass})});
    if(r.status===401){_('rp-err').textContent='Sesi habis, redirect...';_('rp-err').style.display='block';setTimeout(mobRedirectLogin,1500);return;}
    var d = await r.json();
    if (!d.ok) throw new Error(d.error || 'Gagal');
    _('rp-ok').textContent = '✓ Password berhasil direset untuk '+user;
    _('rp-ok').style.display = 'block';
    _('rp-err').style.display = 'none';
    _('rp-pass').value = '';
  } catch(x) {
    _('rp-err').textContent = x.message;
    _('rp-err').style.display = 'block';
    _('rp-ok').style.display = 'none';
  }
}

/* ════════ ACCOUNT — FORCE LOGOUT ════════ */
async function mobForceLogout(user) {
  if (!confirm('Logout perangkat '+user+'?')) return;
  try {
    var r = await fetch('/api/dev/admins/force-logout', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({username:user})});
    if(r.status===401){toast('Sesi habis, redirect...');setTimeout(mobRedirectLogin,1500);return;}
    var d = await r.json();
    if (!d.ok) throw new Error(d.error || 'Gagal');
    toast('✓ '+user+' telah di-logout');
  } catch(x) { toast('Gagal: '+x.message); }
}

/* ════════ ACTIVITY — FILTER LOGS ════════ */
function mobRenderLogs(filter) {
  var logs=window._mobLogs||[];
  var list=_('ac-list'), empty=_('ac-empty');
  if(!list) return;
  var filtered = filter==='all'?logs:logs.filter(function(l){return l.action&&l.action.split('.')[0]===filter;});
  if(filtered.length){
    list.style.display='block';
    if(empty) empty.style.display='none';
    var html='';
    filtered.forEach(function(l){
      var cat=l.action?l.action.split('.')[0]:'other';
      var iconSvg=cat==='admin'?'<path d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-1.13a4 4 0 10-4-4 4 4 0 004 4zm6 0a4 4 0 10-3-6.65"/>':
        cat==='event'?'<path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>':
        cat==='backup'?'<path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>':
        cat==='security'||cat==='maintenance'?'<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>':
        '<circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>';
      var ts=l.timestamp?new Date(l.timestamp).toLocaleString('id-ID'):'—';
      var detail=l.detail||'';
      var uname=l.username||'system';
      html+='<div class="account-item" style="border-left:3px solid '+
        (cat==='admin'?'#8B5CF6':cat==='event'?'#3B82F6':cat==='backup'?'#6366F1':cat==='security'?'#EF4444':cat==='maintenance'?'#F59E0B':'#94A3B8')+
        ';padding-left:10px;">'+
        '<div class="account-item-left" style="flex:1;">'+
          '<div class="account-item-info">'+
            '<span style="font-size:10px;color:var(--muted);text-transform:uppercase;font-weight:700;">'+(l.action||'unknown')+'</span>'+
            '<span class="account-item-name" style="font-size:12px;">'+detail+'</span>'+
            '<span style="font-size:10px;color:#64748b;margin-top:2px;">👤 '+uname+' · 🕐 '+ts+'</span>'+
          '</div>'+
        '</div>'+
      '</div>';
    });
    list.innerHTML=html;
  }else{
    list.style.display='none';
    if(empty){empty.style.display='block';empty.textContent='Tidak ada log untuk kategori ini.';}
  }
}

function mobFilterLogs(filter) {
  document.querySelectorAll('.al-filter').forEach(function(b){b.style.color='var(--muted)';b.style.background='var(--surface)';});
  var active=document.querySelector('.al-filter[data-filter="'+filter+'"]');
  if(active){active.style.color='var(--text)';active.style.background='var(--blue-bg)';}
  mobRenderLogs(filter);
}

/* ════════ ACCOUNT — ADD ADMIN ════════ */
function mobShowAddAdmin() {
  _('aa-username').value='';
  _('aa-password').value='';
  _('aa-err').style.display='none';
  _('aa-ok').style.display='none';
  _('aa-modal').classList.add('active');
}

async function mobAddAdmin() {
  var user=_('aa-username').value.trim();
  var pass=_('aa-password').value.trim();
  if(!user||user.length<2){_('aa-err').textContent='Username minimal 2 karakter';_('aa-err').style.display='block';return;}
  if(!pass||pass.length<4){_('aa-err').textContent='Password minimal 4 karakter';_('aa-err').style.display='block';return;}
  try{
    var r=await fetch('/api/dev/admins/add',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:user,password:pass})});
    if(r.status===401){_('aa-err').textContent='Sesi habis, redirect...';_('aa-err').style.display='block';setTimeout(mobRedirectLogin,1500);return;}
    var d=await r.json();
    if(!d.ok)throw new Error(d.error||'Gagal');
    _('aa-ok').textContent='✓ Admin "'+user+'" berhasil ditambahkan!';
    _('aa-ok').style.display='block';
    _('aa-err').style.display='none';
    _('aa-username').value='';
    _('aa-password').value='';
    setTimeout(function(){mobCloseModal('aa-modal');mobRefresh();},1500);
  }catch(x){_('aa-err').textContent=x.message;_('aa-err').style.display='block';_('aa-ok').style.display='none';}
}

/* ════════ ACCOUNT — DELETE ADMIN ════════ */
var _deleteUser=null;
function mobShowDelete(user) {
  _deleteUser=user;
  _('da-username-display').textContent=user;
  _('da-err').style.display='none';
  _('da-ok').style.display='none';
  _('da-modal').classList.add('active');
}

async function mobDeleteAdmin() {
  if(!_deleteUser)return;
  try{
    var r=await fetch('/api/dev/admins/delete',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:_deleteUser})});
    if(r.status===401){_('da-err').textContent='Sesi habis, redirect...';_('da-err').style.display='block';setTimeout(mobRedirectLogin,1500);return;}
    var d=await r.json();
    if(!d.ok)throw new Error(d.error||'Gagal');
    _('da-ok').textContent='✓ Admin "'+_deleteUser+'" berhasil dihapus';
    _('da-ok').style.display='block';
    _('da-err').style.display='none';
    setTimeout(function(){mobCloseModal('da-modal');mobRefresh();},1500);
  }catch(x){_('da-err').textContent=x.message;_('da-err').style.display='block';_('da-ok').style.display='none';}
}

/* ════════ BACKUP ════════ */
var _mobBackingUp = false;

async function mobLoadBackupStatus() {
  try {
    var r = await fetch('/api/dev/backup/status');
    if (r.status === 401) { toast('Sesi habis, redirect...'); return; }
    var d = await r.json();

    if (d.hasBackup && d.latestBackup) {
      var lb = d.latestBackup;
      var dt = new Date(lb.createdAt);
      _('hm-bk-last').textContent = dt.toLocaleDateString('id-ID', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' });
      _('hm-bk-events').textContent = (lb.summary && lb.summary.events) || '—';
      _('hm-bk-songs').textContent = (lb.summary && lb.summary.songs) || '—';
      _('hm-bk-admins').textContent = (lb.summary && lb.summary.admins) || '—';
    } else {
      _('hm-bk-last').textContent = 'Never';
      _('hm-bk-events').textContent = '—';
      _('hm-bk-songs').textContent = '—';
      _('hm-bk-admins').textContent = '—';
    }
  } catch(e) {}
}

async function mobCreateBackup() {
  if (_mobBackingUp) return;
  _mobBackingUp = true;
  var btn = _('hm-bk-btn');
  var qbtn = _('hm-bk-qbtn');
  var fb = _('hm-bk-feedback');
  var origText = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;animation:loading-spin 0.8s linear infinite;"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg> Backing up...';
  if (qbtn) { qbtn.style.opacity = '0.5'; qbtn.style.pointerEvents = 'none'; }
  fb.style.display = 'none';
  fb.classList.remove('success', 'error');
  try {
    var r = await fetch('/api/dev/backup/create', { method:'POST' });
    if (r.status === 401) {
      toast('Sesi habis, redirect...');
      setTimeout(mobRedirectLogin, 1500);
      return;
    }
    var d = await r.json();
    if (d.ok) {
      fb.textContent = '✅ Backup berhasil!';
      fb.className = 'mt-feedback success';
      fb.style.display = 'block';
      mobLoadBackupStatus();
      mobRefresh();
    } else {
      fb.textContent = '❌ ' + (d.error || 'Gagal');
      fb.className = 'mt-feedback error';
      fb.style.display = 'block';
    }
  } catch(e) {
    fb.textContent = '❌ Error: ' + e.message;
    fb.className = 'mt-feedback error';
    fb.style.display = 'block';
  }
  setTimeout(function() {
    fb.style.display = 'none';
  }, 4000);
  btn.innerHTML = origText;
  btn.disabled = false;
  if (qbtn) { qbtn.style.opacity = '1'; qbtn.style.pointerEvents = 'auto'; }
  _mobBackingUp = false;
}

/* ════════ ACCOUNT — LOGOUT ALL ════════ */
async function mobLogoutAll() {
  if (!confirm('Logout semua perangkat admin?')) return;
  try {
    var r = await fetch('/api/dev/admins/force-logout-all', {method:'POST'});
    if(r.status===401){toast('Sesi habis, redirect...');setTimeout(mobRedirectLogin,1500);return;}
    var d = await r.json();
    if (!d.ok) throw new Error(d.error || 'Gagal');
    toast('✓ Semua perangkat telah di-logout');
  } catch(x) { toast('Gagal: '+x.message); }
}

/* ════════ INIT ════════ */
document.addEventListener('DOMContentLoaded', function() {
  mobRefresh();
  mobLoadBackupStatus();
  setInterval(mobRefresh, 30000);
  setInterval(mobLoadBackupStatus, 30000);
});
</script>

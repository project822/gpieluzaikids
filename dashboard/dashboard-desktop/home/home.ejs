<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Home — Dev Console</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap"></noscript>
    <%- include('_critical-css') %>
    <link rel="stylesheet" href="/dashboard-assets/shared/base.css" media="print" onload="this.media='all'">
    <link rel="stylesheet" href="/dashboard-assets/dashboard-desktop/home/home.css" media="print" onload="this.media='all'">
    <script>window.va=window.va||function(){(window.vaq=window.vaq||[]).push(arguments)};</script>
    <script defer src="/_vercel/insights/script.js"></script>
  </head>
<body>
  <div class="dash-shell">
    <%- include('_sidebar', { active: 'home' }) %>
    <div class="main">
      <header class="topbar">
        <div class="topbar-heading">
          <button class="hamburger" onclick="toggleSidebar()" aria-label="Toggle sidebar">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
          <h1>Home</h1>
          <p>Ringkasan sistem dan kontrol cepat.</p>
        </div>
        <div class="topbar-actions">
          <div class="online-badge">
            <span class="online-dot"></span>
            <span><%= pvStats ? pvStats.online : 0 %></span> online
          </div>
          <a href="/admin/events" class="btn">Admin Panel</a>
        </div>
      </header>
      <main class="content">

        <!-- ── TOP STAT GRID ── -->
        <div class="stat-grid">
          <div class="stat-card">
            <div class="stat-label">Visitors (7d)</div>
            <div class="stat-value"><%= pvStats ? pvStats.visitors : 0 %></div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Page Views</div>
            <div class="stat-value"><%= pvStats ? pvStats.pageviews : 0 %></div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Avg Latency</div>
            <div class="stat-value"><%= avgLatencyMs %>ms</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Admin Accounts</div>
            <div class="stat-value"><%= admins ? admins.length : 0 %></div>
          </div>
        </div>

        <!-- ── SYSTEM STATUS ROW ── -->
        <div class="ov-status-row">
          <div class="ov-status-card" id="ov-card-website">
            <div class="ov-status-dot" id="ov-dot-website"></div>
            <div class="ov-status-body">
              <div class="ov-status-label">Website</div>
              <div class="ov-status-val" id="ov-val-website">Checking...</div>
            </div>
            <span class="ov-status-pill" id="ov-pill-website">—</span>
          </div>
          <div class="ov-status-card" id="ov-card-db">
            <div class="ov-status-dot" id="ov-dot-db"></div>
            <div class="ov-status-body">
              <div class="ov-status-label">Database</div>
              <div class="ov-status-val" id="ov-val-db">Checking...</div>
            </div>
            <span class="ov-status-pill" id="ov-pill-db">—</span>
          </div>
          <div class="ov-status-card">
            <div class="ov-status-dot ok"></div>
            <div class="ov-status-body">
              <div class="ov-status-label">Admin Accounts</div>
              <div class="ov-status-val"><%= admins ? admins.length : 0 %> registered</div>
            </div>
            <a href="/dev/dashboard-desktop/admins" class="ov-status-pill ok" style="text-decoration:none;">Manage</a>
          </div>
          <div class="ov-status-card" id="ov-card-mt">
            <div class="ov-status-dot <%= maintenanceMode && maintenanceMode.enabled ? 'warn' : 'ok' %>" id="ov-dot-mt"></div>
            <div class="ov-status-body">
              <div class="ov-status-label">Maintenance Mode</div>
              <div class="ov-status-val" id="ov-val-mt"><%= maintenanceMode && maintenanceMode.enabled ? 'ACTIVE — users blocked' : 'Inactive' %></div>
            </div>
            <label class="ov-mini-toggle" title="Toggle Maintenance">
              <input type="checkbox" id="ov-mt-toggle" <%= maintenanceMode && maintenanceMode.enabled ? 'checked' : '' %> onchange="ovToggleMaintenance(this.checked)">
              <span class="ov-mini-slider"></span>
            </label>
          </div>
        </div>

        <!-- ── QUICK NAV LINKS ── -->
        <div class="overview-grid">
          <a href="/dev/dashboard-desktop/admins" class="card overview-link-card">
            <div class="overview-link-icon" style="background:var(--green-bg);color:var(--green);">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-1.13a4 4 0 10-4-4 4 4 0 004 4zm6 0a4 4 0 10-3-6.65"/></svg>
            </div>
            <div>
              <div class="overview-link-title">Accounts</div>
              <div class="overview-link-sub">Manage admin accounts &amp; access</div>
            </div>
          </a>

          <a href="/dev/dashboard-desktop/maintenance" class="card overview-link-card">
            <div class="overview-link-icon" style="background:var(--orange-bg);color:var(--orange);">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <div class="overview-link-title">Maintenance</div>
              <div class="overview-link-sub">Toggle user-facing maintenance page</div>
            </div>
          </a>
          <a href="/dev/dashboard-desktop/security" class="card overview-link-card">
            <div class="overview-link-icon" style="background:rgba(124,58,237,0.10);color:#7C3AED;">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div>
              <div class="overview-link-title">Security</div>
              <div class="overview-link-sub">Firewall, blocked IPs &amp; bot detection</div>
            </div>
          </a>
        </div>

        <!-- ── REAL-TIME HEALTH CHECK (Server) ── -->
        <div class="ov-health-row">

          <!-- Server metrics compact card -->
          <div class="card ov-server-card">
            <div class="section-header">
              <span>Server Status</span>
              <span class="sub">Express / Node.js</span>
            </div>
            <div class="ov-server-grid">
              <div class="ov-srow">
                <span class="ov-skey">Total Requests</span>
                <span class="ov-sval" id="ov-s-requests"><%= metrics && metrics.totalRequests ? metrics.totalRequests : 0 %></span>
              </div>
              <div class="ov-srow">
                <span class="ov-skey">Avg Latency</span>
                <span class="ov-sval" id="ov-s-latency"><%= avgLatencyMs %>ms</span>
              </div>
              <div class="ov-srow">
                <span class="ov-skey">Last Request</span>
                <span class="ov-sval" id="ov-s-last" style="font-size:12px;">
                  <% if (metrics && metrics.lastRequestAt) { %>
                    <%= new Date(metrics.lastRequestAt).toLocaleString('id-ID') %>
                  <% } else { %>—<% } %>
                </span>
              </div>
              <div class="ov-srow">
                <span class="ov-skey">DB Status</span>
                <span class="ov-sval" id="ov-s-db">Checking...</span>
              </div>
              <div class="ov-srow">
                <span class="ov-skey">Uptime</span>
                <span class="ov-sval" id="ov-s-uptime">—</span>
              </div>
              <div class="ov-srow">
                <span class="ov-skey">Memory Used</span>
                <span class="ov-sval" id="ov-s-mem">—</span>
              </div>
            </div>

          </div>

        </div>

      </main>
    </div>
  </div>

  <script>
  function fmtUptime(s) {
    if (s < 60) return s + 's';
    if (s < 3600) return Math.floor(s/60) + 'm';
    return Math.floor(s/3600) + 'h ' + Math.floor((s%3600)/60) + 'm';
  }
  function setOvStatus(id, status, pillText, valText) {
    const card = document.getElementById('ov-card-' + id);
    const dot  = document.getElementById('ov-dot-' + id);
    const pill = document.getElementById('ov-pill-' + id);
    const val  = document.getElementById('ov-val-' + id);
    if (card) card.className = 'ov-status-card ' + status;
    if (dot)  dot.className  = 'ov-status-dot ' + status;
    if (pill) { pill.textContent = pillText; pill.className = 'ov-status-pill ' + status; }
    if (val)  val.textContent = valText;
  }

  function redirectLogin() {
    window.location.href = '/dev/login';
  }

  function showSessionExpired() {
    setOvStatus('website','error','Session Expired','—');
    setOvStatus('db','error','Session Expired','—');
    document.getElementById('ov-s-db').textContent = '✗ Session expired';
    document.getElementById('ov-s-db').style.color = 'var(--red)';
    document.getElementById('ov-s-uptime').textContent = '—';
    document.getElementById('ov-s-mem').textContent = '—';
    document.getElementById('ov-s-requests').textContent = '—';
    document.getElementById('ov-s-latency').textContent = '—';
  }

  async function ovLoadHealth() {
    try {
      const t0 = performance.now();
      const res = await fetch('/api/dev/health');
      const ping = Math.round(performance.now() - t0);

      // Jika 401 (session expired), redirect ke login
      if (res.status === 401) {
        showSessionExpired();
        setTimeout(redirectLogin, 2000);
        return;
      }

      if (!res.ok) {
        setOvStatus('website','error','Error','Check failed');
        setOvStatus('db','error','Unknown','Check failed');
        return;
      }

      const d = await res.json();
      setOvStatus('website', d.website === 'ok' ? 'ok' : 'error',
        d.website === 'ok' ? 'Online' : 'Error',
        d.website === 'ok' ? ping + 'ms' : 'Degraded');
      setOvStatus('db', d.db === 'ok' ? 'ok' : 'error',
        d.db === 'ok' ? 'Connected' : 'Disconnected',
        d.db === 'ok' ? (d.dbPingMs + 'ms ping') : (d.dbError || 'Failed'));
      document.getElementById('ov-s-db').textContent     = d.db === 'ok' ? '✓ ' + d.dbPingMs + 'ms' : '✗ Disconnected';
      document.getElementById('ov-s-db').style.color     = d.db === 'ok' ? 'var(--green)' : 'var(--red)';
      document.getElementById('ov-s-uptime').textContent = fmtUptime(d.uptimeSeconds || 0);
      document.getElementById('ov-s-mem').textContent    = d.memHeapUsedMB ? d.memHeapUsedMB + ' MB' : '—';
      document.getElementById('ov-s-requests').textContent = d.totalRequests != null ? d.totalRequests : '—';
      document.getElementById('ov-s-latency').textContent  = (d.avgLatencyMs || 0) + 'ms';
    } catch(e) {
      setOvStatus('website','error','Error','Check failed');
      setOvStatus('db','error','Unknown','Check failed');
    }
  }

  async function ovToggleMaintenance(enabled) {
    const dot  = document.getElementById('ov-dot-mt');
    const val  = document.getElementById('ov-val-mt');
    try {
      const res = await fetch('/api/dev/maintenance', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ enabled }),
      });

      // Jika 401 (session expired), redirect ke login
      if (res.status === 401) {
        document.getElementById('ov-mt-toggle').checked = !enabled;
        alert('Sesi telah berakhir. Anda akan diarahkan ke halaman login.');
        window.location.href = '/dev/login';
        return;
      }

      const d = await res.json();
      if (!d.ok) throw new Error(d.error);
      if (dot) dot.className = 'ov-status-dot ' + (enabled ? 'warn' : 'ok');
      if (val) val.textContent = enabled ? 'ACTIVE — users blocked' : 'Inactive';
      const badge = document.getElementById('sidebar-mt-badge');
      if (badge) badge.style.display = enabled ? 'inline-flex' : 'none';
    } catch(e) {
      document.getElementById('ov-mt-toggle').checked = !enabled;
      // Jangan tampilkan alert untuk error yang sudah di-handle (401)
      if (!e.message.includes('Sesi telah berakhir')) {
        alert('Gagal toggle maintenance: ' + e.message);
      }
    }
  }

  ovLoadHealth();
  setInterval(ovLoadHealth, 30000);
  </script>
</body>
</html>

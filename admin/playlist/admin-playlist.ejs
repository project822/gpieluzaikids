<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Admin Playlist — GPI Eluzai Kids</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@600;700;800&family=Inter:wght@400;500;600;700&display=optional">
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Inter',sans-serif;background:#0F172A;color:#E2E8F0;min-height:100vh;padding:24px}
    .wrap{max-width:1000px;margin:0 auto}
    h1{font-family:'Hanken Grotesk',sans-serif;font-size:28px;font-weight:800;margin-bottom:24px;display:flex;align-items:center;gap:12px}
    h1 a{font-size:14px;font-weight:600;color:#3B82F6;text-decoration:none}
    h1 a:hover{text-decoration:underline}
    .toolbar{display:flex;align-items:center;justify-content:space-between;gap:16px;margin-bottom:20px;flex-wrap:wrap}
    .btn{display:inline-flex;align-items:center;gap:6px;padding:10px 20px;border-radius:8px;border:none;font-family:'Inter',sans-serif;font-weight:600;font-size:14px;cursor:pointer;text-decoration:none;transition:all .15s}
    .btn-primary{background:#3B82F6;color:#fff}
    .btn-primary:hover{background:#2563EB}
    .btn-danger{background:#DC2626;color:#fff}
    .btn-danger:hover{background:#B91C1C}
    .btn-sm{padding:6px 12px;font-size:12px}
    .table{width:100%;border-collapse:collapse;background:#1E293B;border-radius:12px;overflow:hidden}
    .table th{padding:12px 16px;text-align:left;font-size:11px;font-weight:700;color:#64748B;text-transform:uppercase;letter-spacing:.05em;background:#16213A;border-bottom:1px solid #334155}
    .table td{padding:12px 16px;border-bottom:1px solid #334155;font-size:14px;vertical-align:middle}
    .table tr:last-child td{border-bottom:none}
    .table tr:hover td{background:rgba(59,130,246,.04)}
    .actions{display:flex;gap:6px}
    .actions a,.actions button{padding:6px 12px;border-radius:6px;font-size:12px;font-weight:600;cursor:pointer;text-decoration:none;border:none;font-family:'Inter',sans-serif;transition:all .15s}
    .actions .edit{background:rgba(59,130,246,.12);color:#3B82F6}
    .actions .edit:hover{background:rgba(59,130,246,.2)}
    .actions .del{background:rgba(220,38,38,.12);color:#DC2626}
    .actions .del:hover{background:rgba(220,38,38,.2)}
    .empty{text-align:center;padding:60px 20px;color:#64748B}
    .empty p{margin-top:8px;font-size:14px}
    .error{background:rgba(220,38,38,.1);border:1px solid rgba(220,38,38,.3);border-radius:8px;padding:12px 16px;color:#DC2626;font-weight:600;font-size:14px;margin-bottom:16px}
    .lyrics-preview{font-size:12px;color:#64748B;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .badge{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:999px;font-size:11px;font-weight:700;background:rgba(59,130,246,.1);color:#3B82F6}
    .badge.fav{background:rgba(245,158,11,.1);color:#F59E0B}
    .nav-links{display:flex;gap:12px;margin-bottom:24px;flex-wrap:wrap}
    .nav-links a{color:#64748B;text-decoration:none;font-size:13px;font-weight:600;transition:color .15s}
    .nav-links a:hover{color:#E2E8F0}
  </style>
</head>
<body>
  <div class="wrap">
    <div class="nav-links">
      <a href="/admin/events">← Admin Events</a>
      <a href="/admin-playlist">Playlist</a>
      <a href="/admin/logout">Logout</a>
    </div>

    <h1>
      🎵 Admin Playlist
      <a href="/playlist" target="_blank">Lihat halaman publik →</a>
    </h1>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <div class="toolbar">
      <span style="color:#64748B;font-size:14px;"><%= songs ? songs.length : 0 %> lagu</span>
      <a href="/admin-playlist/add" class="btn btn-primary">+ Tambah Lagu</a>
    </div>

    <% if (!songs || songs.length === 0) { %>
      <div class="empty">
        <div style="font-size:48px;margin-bottom:12px;">🎵</div>
        <p>Belum ada lagu. Klik "Tambah Lagu" untuk menambahkan lagu pertama.</p>
      </div>
    <% } else { %>
      <table class="table">
        <thead>
          <tr>
            <th>#</th>
            <th>Judul</th>
            <th>Lirik</th>
            <th>Status</th>
            <th>Dibuat</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% songs.forEach((song, i) => { %>
            <tr>
              <td style="color:#64748B;font-weight:600;"><%= i + 1 %></td>
              <td style="font-weight:600;"><%= song.title %></td>
              <td><div class="lyrics-preview"><%= (song.lyrics || '').substring(0, 60) || '-' %></div></td>
              <td>
                <% if (song.favorite) { %>
                  <span class="badge fav">⭐ Favorit</span>
                <% } else { %>
                  <span class="badge">—</span>
                <% } %>
              </td>
              <td style="font-size:12px;color:#64748B;">
                <%= song.createdAt ? new Date(song.createdAt).toLocaleDateString('id-ID') : '-' %>
              </td>
              <td>
                <div class="actions">
                  <a href="/admin-playlist/<%= song.id %>/edit" class="edit">Edit</a>
                  <form method="post" action="/admin-playlist/<%= song.id %>/delete" style="display:inline;" onsubmit="return confirm('Hapus lagu &quot;<%= song.title %>&quot;?')">
                    <input type="hidden" name="_method" value="DELETE">
                    <button type="submit" class="del">Hapus</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </div>
</body>
</html>

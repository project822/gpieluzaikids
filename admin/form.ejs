<%- include('../../../frontend/views/partials/header', { title: 'Admin - Event Form', hideNavbar: true }) %>

<div class="section admin-form-card">
  <div class="section-header" style="text-align: left; margin-left: 0;">
    <h1><%= event ? 'Edit' : 'New' %> Event</h1>
    <p>Lengkapi detail event</p>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="form-error" style="background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.4);color:#ef4444;padding:12px 14px;border-radius:10px;margin-bottom:16px;">
      <%= error %>
    </div>
  <% } %>

  <form
    class="admin-form"
    method="post"
    action="<%= event ? ('/admin/events/' + event.id + '/edit') : '/admin/events/new' %>"
    enctype="multipart/form-data"
  >
  <label>
    Title
    <input
      name="title"
      value="<%= event ? event.title : '' %>"
      required
    >
  </label>

  <label>
    Date
    <input
      type="date"
      name="day"
      value="<%= event ? (event.day || '') : '' %>"
    >
  </label>

  <label>
    Time
    <input
      type="time"
      name="time"
      value="<%= event ? (event.time || '') : '' %>"
    >
  </label>

  <label>
    Location
    <input
      name="location"
      value="<%= event ? event.location : '' %>"
    >
  </label>

  <label>
    Google Form URL
    <input
      name="googleForm"
      value="<%= event ? event.googleForm : '' %>"
    >
  </label>

  <label>
    Poster (optional)
    <input type="file" name="poster" accept="image/*">
    <small style="display:block; margin-top:4px; color: var(--muted, #94a3b8); font-weight:400;">
      Gambar otomatis di-crop ke rasio 9:16. Maksimal ukuran file 4MB.
    </small>
  </label>

  <div class="form-actions">
    <button class="btn primary" type="submit">Save</button>
    <a class="btn ghost" href="/admin/events">Cancel</a>
  </div>
  </form>
</div>

<%- include('../../../frontend/views/partials/footer') %>

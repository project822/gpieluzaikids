# =============================================================
# CONFIGURASI LINGKUNGAN — Gereja Landing Page
# =============================================================
# Copy file ini ke .env dan isi nilai-nilainya:
#   cp .env.example .env
# =============================================================

# ─── DATABASE ─────────────────────────────────────────────────
# WAJIB: Connection string MongoDB Atlas (free tier).
# Dapat dari: MongoDB Atlas > Cluster > Connect > Connect your application
# Contoh: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net
MONGO_URI=

# Nama database (default: "gereja")
MONGO_DB_NAME=gereja

# ─── SESSION ─────────────────────────────────────────────────
# WAJIB: String acak untuk menandatangani cookie session.
# Penting di Vercel serverless — tanpa ini session tidak persist.
# Generate: node -e "console.log(require('crypto').randomUUID())"
SESSION_SECRET=

# ─── DEV DASHBOARD ────────────────────────────────────────────
# Username untuk login dashboard developer (default: "dev")
DEV_USERNAME=dev

# WAJIB: bcrypt hash dari password dev dashboard.
# Generate: node -e "
#   require('bcrypt').hash('password123', 10).then(h => console.log(h))
# "
DEV_PASSWORD_HASH=

# ─── DEFAULT ADMIN (hanya untuk inisialisasi pertama) ─────────
# Admin pertama otomatis dibuat jika belum ada admin satupun.
# Set DISABLE_DEFAULT_ADMIN=1 setelah deploy pertama untuk keamanan.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DISABLE_DEFAULT_ADMIN=

# ─── APLIKASI ─────────────────────────────────────────────────
# Port untuk development lokal (default: 10082)
PORT=10082

# Environment: "production" untuk Vercel, "" untuk lokal
NODE_ENV=

# ─── (DULU) GOOGLE PAGESPEED INSIGHTS ─────────────────────────
# Fitur ini sudah dihapus. Tidak perlu diisi.
# GOOGLE_PAGESPEED_API_KEY=

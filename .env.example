# ============== MongoDB (wajib untuk production) ==============
# Dapatkan dari MongoDB Atlas → Connect → Drivers
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/gereja?retryWrites=true&w=majority

# ============== Opsional ==============
# Nama database (default: "gereja")
# MONGO_DB_NAME=gereja

# Secret untuk session cookie (ubah untuk production!)
# SESSION_SECRET=your-random-secret-here

# Vercel Speed Insights (opsional)
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=

# Google PageSpeed Insights API Key (opsional)
# GOOGLE_PAGESPEED_API_KEY=
